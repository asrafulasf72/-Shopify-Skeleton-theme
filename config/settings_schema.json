[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
      "name": "Logo & Favicon",
      "settings": [
        {
        "type": "image_picker",
        "id": "logo",
        "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "favicon",
          "label": "Favicon"
        }
      ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "Color",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Background",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "Background gradient"
          },
          {
            "type": "color",
            "id": "text",
            "label": "Text",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button",
            "label": "Solid button background",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "Solid button label",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "Outline button",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "shadow",
            "label": "Shadow",
            "default": "#121212"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "secondary_button_label",
          "secondary_button_border": "secondary_button_label",
          "icons": "text"
        }
      }
    ]
  },
  {
    "name": "Color Swatch",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_color_swatch",
        "label": "Enable Product Color Swatch",
        "default":false
        
      },
      {
        "type": "textarea",
        "id": "color_defination",
        "label": "Color Defination",
        "default":"black | #000000, white | #ffffff, red | #ff0000, blue | #0000ff, yellow | #FFFF00",
        "info": "black | #000000, white | #ffffff, red | #ff0000, blue | #0000ff, yellow | #FFFF00"
      }
    ]
  }
]
