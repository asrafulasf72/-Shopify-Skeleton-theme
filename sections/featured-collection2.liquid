{% liquid
  # Padding: use one desktop value and scale it for laptop, tablet, and mobile
  assign padding_top = section.settings.padding_top | default: 0
  assign laptop_padding_top = padding_top | times: 80 | divided_by: 100
  assign tab_padding_top = laptop_padding_top | times: 80 | divided_by: 100
  assign mobile_padding_top = tab_padding_top | times: 50 | divided_by: 100

  assign padding_bottom = section.settings.padding_bottom | default: 0
  assign laptop_padding_bottom = padding_bottom | times: 80 | divided_by: 100
  assign tab_padding_bottom = laptop_padding_bottom | times: 80 | divided_by: 100
  assign mobile_padding_bottom = tab_padding_bottom | times: 50 | divided_by: 100

  # margin: use one desktop value and scale it for laptop, tablet, and mobile
  assign margin_top = section.settings.margin_top | default: 0
  assign laptop_margin_top = margin_top | times: 80 | divided_by: 100
  assign tab_margin_top = laptop_margin_top | times: 80 | divided_by: 100
  assign mobile_margin_top = tab_margin_top | times: 50 | divided_by: 100

  assign margin_bottom = section.settings.margin_bottom | default: 0
  assign laptop_margin_bottom = margin_bottom | times: 80 | divided_by: 100
  assign tab_margin_bottom = laptop_margin_bottom | times: 80 | divided_by: 100
  assign mobile_margin_bottom = tab_margin_bottom | times: 50 | divided_by: 100
%}


<div
  class="nv-featured-collection-section shopify-section-{{ section.id }} color-{{ section.settings.color_schemes }}"
  id="featured-collection-{{ section.id }}"
>
  {% render 'heading', title: section.settings.heading %}
  <div class="nv-featured-collection-inner">
    <div class="nv-container">
      <div class="nv-featured-collection-wrapper">
        <article
          class="nv-featured-collection-card nv-featured-collection-card-one {% if section.settings.card_1_image == blank %}nv-featured-collection-card--placeholder{% endif %}"
          aria-label="{{ section.settings.card_1_title | escape }}"
        >
          {%- if section.settings.card_1_image == blank -%}
            {{ 'collection-1' | placeholder_svg_tag: 'nv-featured-collection-placeholder-svg' }}
          {%- endif -%}
          <div class="nv-featured-collection-card__content">
            {%- if section.settings.card_1_title != blank -%}
              <h2
                class="nv-featured-collection-card__title"
                style="color: {{ section.settings.left_heading_color }}; max-width: {{ section.settings.card_1_title_width }}px;"
              >
                {{ section.settings.card_1_title }}
              </h2>
            {%- endif -%}
            {%- if section.settings.card_1_link_label != blank -%}
              
              <a  href="{{ section.settings.card_1_link_url }}"
                class="nv-featured-collection-card__link"
                style="color: {{ section.settings.left_subtext_color }}"
                aria-label="{{ section.settings.card_1_link_label | escape }} - {{ section.settings.card_1_title | escape }}"
              >
                {{- section.settings.card_1_link_label -}}
              </a>
            {%- endif -%}
          </div>
        </article>
        <article
          class="nv-featured-collection-card nv-featured-collection-card-two {% if section.settings.card_2_image == blank %}nv-featured-collection-card--placeholder{% endif %}"
          aria-label="{{ section.settings.card_2_title | escape }}"
        >
          {%- if section.settings.card_2_image == blank -%}
            {{ 'collection-2' | placeholder_svg_tag: 'nv-featured-collection-placeholder-svg' }}
          {%- endif -%}
          <div class="nv-featured-collection-card__content">
            {%- if section.settings.card_2_title != blank -%}
              <h2
                class="nv-featured-collection-card__title"
                style="color: {{ section.settings.right_heading_color }}; max-width: {{ section.settings.card_2_title_width }}px;"
              >
                {{ section.settings.card_2_title }}
              </h2>
            {%- endif -%}
            {%- if section.settings.card_2_link_label != blank -%}
              
               <a href="{{ section.settings.card_2_link_url }}"
                class="nv-featured-collection-card__link"
                style="color: {{ section.settings.right_subtext_color }}"
                aria-label="{{ section.settings.card_2_link_label | escape }} - {{ section.settings.card_2_title | escape }}"
              >
                {{- section.settings.card_2_link_label -}}
              </a>
            {%- endif -%}
          </div>
        </article>
      </div>
    </div>
  </div>
</div>

{% style %}
  /* Mobile: base spacing and single-column grid */
   .shopify-section-{{ section.id }} {
     padding-top: {{ mobile_padding_top }}px;
     padding-bottom: {{ mobile_padding_bottom }}px;
     margin-top: {{ mobile_margin_top }}px;
     margin-bottom: {{ mobile_margin_bottom }}px;
   }
   .nv-featured-collection-wrapper {
     display: grid;
     grid-template-columns: 1fr;
     gap: 1.5rem;
     padding-top:1.25rem
   }
   .nv-featured-collection-card-one,
   .nv-featured-collection-card-two {
     background-position: center;
     background-size: cover;
     background-repeat: no-repeat;
     height: 550px;
   }
   {%- if section.settings.card_1_image != blank -%}
     .nv-featured-collection-card-one {
       background-image: url('{{ section.settings.card_1_image | image_url: width: 2000 }}');
     }
   {%- endif -%}
   {%- if section.settings.card_2_image != blank -%}
     .nv-featured-collection-card-two {
       background-image: url('{{ section.settings.card_2_image | image_url: width: 2000 }}');
     }
   {%- endif -%}
   h2.nv-featured-collection-card__title {
     font-size: clamp(2rem, 5vw, 2.625rem);
     word-break: break-word;
     overflow-wrap: break-word
   }
   .nv-featured-collection-card__link{
     text-decoration: underline;
     font-size:1rem;
   }
   .nv-featured-collection-card__content {
     position: sticky;
     top: 6.25rem;
     margin: 2.625rem 0 0 2.125rem;
     padding-bottom: 2.625rem;
     color: var(--nv-text);
     z-index: 2;
   }
   .nv-featured-collection-card--placeholder {
     background-color: var(--nv-background);
     position: relative;
     /* overflow: hidden; */
   }

   .nv-featured-collection-placeholder-svg {
     position: absolute;
     top: 0;
     left: 0;
     width: 100%;
     height: 100%;
     object-fit: cover;
   }
   @media (min-width: 768px) {
         /* Tablet: use tablet padding and column setting */
     .shopify-section-{{ section.id }} {
       padding-top: {{ tab_padding_top }}px;
       padding-bottom: {{ tab_padding_bottom }}px;
       margin-top: {{ tab_margin_top }}px;
       margin-bottom: {{ tab_margin_bottom }}px;
     }
     .nv-featured-collection-wrapper {
       grid-template-columns: 1fr 1fr;
       padding-top:1.875rem;
     }

     .nv-featured-collection-card {
       height: 550px;
     }
   }
   @media (min-width: 992px) {

         /* Laptop: laptop padding and columns */
     .shopify-section-{{ section.id }} {
       padding-top: {{ laptop_padding_top }}px;
       padding-bottom: {{ laptop_padding_bottom }}px;
       margin-top: {{ laptop_margin_top }}px;
       margin-bottom: {{ laptop_margin_bottom }}px;
     }
       .nv-featured-collection-wrapper {
       padding-top:1.875rem;
     }
     .nv-featured-collection-card {
       height: 750px;
     }
   }
     @media (min-width: 1280px) {
           .shopify-section-{{ section.id }} {
       padding-top: {{ padding_top }}px;
       padding-bottom: {{ padding_bottom }}px;
       margin-top: {{ margin_top }}px;
       margin-bottom: {{ margin_bottom }}px;
     }
     .nv-featured-collection-card {
       height: 850px;
     }
     .nv-featured-collection-wrapper {
       padding-top:1.875rem;
     }
   }
     @media (min-width: 1920px) {
     .nv-featured-collection-card {
       height: 1100px;
     }
     .nv-featured-collection-wrapper {
       padding-top:1.875rem;
     }
   }
{% endstyle %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "nv-featured-collection",
  "settings": [
    {
      "type": "header",
      "content":"t:common.general.content"
    },
    {
      "type": "color_scheme",
      "id": "color_schemes",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading.label",
      "default": "t:sections.featured_collection.settings.heading.default"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:common.padding_top.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:common.padding_bottom.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "t:common.margin_top.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "t:common.margin_bottom.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.settings.card_1_header.content"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "t:sections.featured_collection.settings.card_1_image.label"
    },
    {
      "type": "range",
      "id": "card_1_title_width",
      "label": "t:sections.featured_collection.settings.card_1_title_width.label",
      "min": 20,
      "max": 600,
      "step": 20,
      "default": 420,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "t:sections.featured_collection.settings.card_1_title.label",
      "default": "t:sections.featured_collection.settings.card_1_title.default"
    },
    {
      "type": "color",
      "id": "left_heading_color",
      "label": "t:sections.featured_collection.settings.left_heading_color.label",
      "alpha": true,
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "card_1_link_label",
      "label": "t:sections.featured_collection.settings.card_1_link_label.label",
      "default": "t:sections.featured_collection.settings.card_1_link_label.default"
    },
    {
      "type": "color",
      "id": "left_subtext_color",
      "label": "t:sections.featured_collection.settings.left_subtext_color.label",
      "alpha": true,
      "default": "#ffffff"
    },
    {
      "type": "url",
      "id": "card_1_link_url",
      "label": "t:sections.featured_collection.settings.card_1_link_url.label"
    },
    {
      "type": "header",
      "content": "t:sections.featured_collection.settings.card_2_header.content"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "t:sections.featured_collection.settings.card_2_image.label"
    },
    {
      "type": "range",
      "id": "card_2_title_width",
      "label": "t:sections.featured_collection.settings.card_2_title_width.label",
      "min": 20,
      "max": 600,
      "step": 20,
      "default": 420,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "t:sections.featured_collection.settings.card_2_title.label",
      "default": "t:sections.featured_collection.settings.card_2_title.default"
    },
    {
      "type": "color",
      "id": "right_heading_color",
      "label": "t:sections.featured_collection.settings.right_heading_color.label",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "card_2_link_label",
      "label": "t:sections.featured_collection.settings.card_2_link_label.label",
      "default": "t:sections.featured_collection.settings.card_2_link_label.default"
    },
    {
      "type": "color",
      "id": "right_subtext_color",
      "label": "t:sections.featured_collection.settings.right_subtext_color.label",
      "default": "#ffffff"
    },
    {
      "type": "url",
      "id": "card_2_link_url",
      "label": "t:sections.featured_collection.settings.card_2_link_url.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.presets.default.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}