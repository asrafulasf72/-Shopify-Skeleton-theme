{{ 'announcement-bar.css' | asset_url | stylesheet_tag }}

{% liquid
  # Padding: use one desktop value and scale it for laptop, tablet, and mobile
  assign padding_top = section.settings.padding_top | default: 0
  assign laptop_padding_top = padding_top | times: 80 | divided_by: 100
  assign tab_padding_top = laptop_padding_top | times: 80 | divided_by: 100
  assign mobile_padding_top = tab_padding_top | times: 50 | divided_by: 100

  assign padding_bottom = section.settings.padding_bottom | default: 0
  assign laptop_padding_bottom = padding_bottom | times: 80 | divided_by: 100
  assign tab_padding_bottom = laptop_padding_bottom | times: 80 | divided_by: 100
  assign mobile_padding_bottom = tab_padding_bottom | times: 50 | divided_by: 100
%}

<div
  class="nv-announcement-bar  color-{{ section.settings.color_scheme }} shopify-section-{{ section.id }}"
  role="region"
  aria-label="{{ 'announcement_bar.label' | t }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed }}"
>
  <div class="nv-container">
    <div class="nv-announcement-bar-wrapper">
      {% comment %} LEFT  contact info  {% endcomment %}
      <div class="nv-announcement-bar-left">
        {%- if section.settings.contact_text != blank -%}
          {%- if section.settings.contact_email != blank -%}
            <a
              href="mailto:{{ section.settings.contact_email }}"
              class="nv-announcement-bar-contact nv-underline-hover"
            >
              {{ section.settings.contact_text }}
            </a>
          {%- else -%}
            <span class="nv-announcement-bar-contact">
              {{ section.settings.contact_text }}
            </span>
          {%- endif -%}
        {%- endif -%}
      </div>

      {% comment %} CENTER slider  {% endcomment %}
      <div
        class="nv-announcement-bar-center"
        role="group"
        aria-label="{{ 'announcement_bar.announcements_label' | t }}"
      >
        <button
          class="nv-announcement-bar-arrow nv-announcement-bar-arrow--prev exit-left"
          aria-label="{{ 'announcement_bar.previous_announcement' | t }}"
          {% if section.blocks.size == 1 %}
            hidden
          {% endif %}
        >
          {% render 'icons', icon: 'arrow-left' %}
        </button>

        <div class="nv-announcement-bar-slider" aria-live="polite" aria-atomic="true">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              <div
                class="nv-announcement-bar-slide"
                role="group"
                aria-label="{{ 'announcement_bar.slide_count' | t: current: forloop.index, total: section.blocks.size }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.type == '@app' -%}
                  {% render block %}
                {%- else -%}
                  <p>
                    {%- if block.settings.url != blank -%}
                      <a href="{{ block.settings.url }}" class="nv-announcement-bar-link">
                        {{ block.settings.text | escape }}
                      </a>
                    {%- else -%}
                      {{ block.settings.text | escape }}
                    {%- endif -%}
                  </p>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} fallback default slide {%- endcomment -%}
            <div
              class="nv-announcement-bar-slide"
              role="group"
              aria-label="{{ 'announcement_bar.slide_count' | t: current: 1, total: 2 }}"
            >
              <p>
                {%- if section.settings.default_announcement_url != blank -%}
                  <a href="{{ section.settings.default_announcement_url }}" class="nv-announcement-bar-link">
                    {{ section.settings.default_announcement_text | escape }}
                  </a>
                {%- else -%}
                  {{ section.settings.default_announcement_text | escape }}
                {%- endif -%}
              </p>
            </div>

            <div
              class="nv-announcement-bar-slide"
              role="group"
              aria-label="{{ 'announcement_bar.slide_count' | t: current: 2, total: 2 }}"
            >
              <p>
                {%- if section.settings.default_announcement_url_2 != blank -%}
                  <a href="{{ section.settings.default_announcement_url_2 }}" class="nv-announcement-bar-link">
                    {{ section.settings.default_announcement_text_2 | escape }}
                  </a>
                {%- else -%}
                  {{ section.settings.default_announcement_text_2 | escape }}
                {%- endif -%}
              </p>
            </div>
          {%- endif -%}
        </div>

        <button
          class="nv-announcement-bar-arrow nv-announcement-bar-arrow--next exit-right"
          aria-label="{{ 'announcement_bar.next_announcement' | t }}"
          {% if section.blocks.size == 1 %}
            hidden
          {% endif %}
        >
          {% render 'icons', icon: 'arrow-right' %}
        </button>
      </div>

      {% comment %} RIGHT  locale/currency selector  {% endcomment %}
      <div class="nv-announcement-bar-right">
        {%- if section.settings.show_country_selector -%}
          <div class="nv-announcement-bar-locale">
            <button
              type="button"
              class="nv-announcement-bar-locale-btn"
              aria-expanded="false"
              aria-controls="nv-locale-panel"
              aria-haspopup="dialog"
            >
              {% comment %} {{ localization.country.name }} {% endcomment %}
              {{ localization.language.endonym_name }}
              <span aria-hidden="true" class="nv-local-divider"> | </span>
              ({{ localization.country.currency.iso_code }}
              {{ localization.country.currency.symbol }})

              <span class="nv-announcement-bar-chevron" aria-hidden="true">
                {% render 'icons', icon: 'arrow-down-outline' %}
              </span>
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>

    {% comment %} Main locale panel  {% endcomment %}
    <div
      id="nv-locale-panel"
      class="nv-locale-panel"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'announcement_bar.locale_panel_label' | t }}"
      hidden
    >
      <div id="nv-locale-main" class="nv-locale-panel-inner">
        <button
          type="button"
          class="nv-locale-row"
          id="nv-lang-btn"
          aria-expanded="false"
          aria-controls="nv-lang-panel"
        >
          <span class="nv-locale-row-label">{{ 'announcement_bar.language' | t }}</span>
          <span class="nv-locale-row-value">
            {{ localization.language.endonym_name }}
            {% render 'icons', icon: 'arrow-right-outline' %}
          </span>
        </button>
        <button
          type="button"
          class="nv-locale-row"
          id="nv-currency-btn"
          aria-expanded="false"
          aria-controls="nv-currency-panel"
        >
          <span class="nv-locale-row-label">{{ 'announcement_bar.currency' | t }}</span>
          <span class="nv-locale-row-value">
            {{ localization.country.currency.iso_code }}
            ({{ localization.country.currency.symbol }})
            {% render 'icons', icon: 'arrow-right-outline' %}
          </span>
        </button>
        <div class="nv-locale-row-empty" aria-hidden="true"></div>
      </div>

      {% comment %} Language sub-panel  {% endcomment %}
      <div
        id="nv-lang-panel"
        class="nv-sub-panel"
        hidden
        data-lenis-prevent
        role="group"
        aria-label="{{ 'announcement_bar.select_language' | t }}"
      >
        <p class="nv-sub-panel-header" aria-hidden="true">{{ 'announcement_bar.select_language' | t }}</p>
        {%- form 'localization', id: 'nv-lang-form-sub' -%}
          <ul class="nv-sub-panel-list" role="listbox" aria-label="{{ 'announcement_bar.select_language' | t }}">
            {%- for language in localization.available_languages -%}
              <li
                role="option"
                aria-selected="{% if language.iso_code == localization.language.iso_code %}true{% else %}false{% endif %}"
              >
                <button
                  type="submit"
                  name="locale_code"
                  value="{{ language.iso_code }}"
                  class="nv-sub-panel-item{% if language.iso_code == localization.language.iso_code %} nv-sub-panel-item--active{% endif %}"
                  aria-label="{{ language.endonym_name }}{% if language.iso_code == localization.language.iso_code %} — {{ 'announcement_bar.currently_selected' | t }}{% endif %}"
                >
                  {%- if language.iso_code == localization.language.iso_code -%}
                    {% render 'icons', icon: 'check-2' %}
                  {%- endif -%}
                  {{ language.endonym_name }}
                </button>
              </li>
            {%- endfor -%}
          </ul>
        {%- endform -%}
      </div>

      {% comment %} Currency sub-panel {% endcomment %}
      <div
        id="nv-currency-panel"
        class="nv-sub-panel"
        hidden
        data-lenis-prevent
        role="group"
        aria-label="{{ 'announcement_bar.select_currency' | t }}"
      >
        <p class="nv-sub-panel-header" aria-hidden="true">{{ 'announcement_bar.select_currency' | t }}</p>
        {%- form 'localization', id: 'nv-country-form-sub' -%}
          <ul class="nv-sub-panel-list" role="listbox" aria-label="{{ 'announcement_bar.select_currency' | t }}">
            {%- for country in localization.available_countries -%}
              <li
                role="option"
                aria-selected="{% if country.iso_code == localization.country.iso_code %}true{% else %}false{% endif %}"
              >
                <button
                  type="submit"
                  name="country_code"
                  value="{{ country.iso_code }}"
                  class="nv-sub-panel-item{% if country.iso_code == localization.country.iso_code %} nv-sub-panel-item--active{% endif %}"
                  aria-label="{{ country.name }} {{ country.currency.iso_code }} {{ country.currency.symbol }}{% if country.iso_code == localization.country.iso_code %} — {{ 'announcement_bar.currently_selected' | t }}{% endif %}"
                >
                  {%- if country.iso_code == localization.country.iso_code -%}
                    {% render 'icons', icon: 'check-2' %}
                  {%- endif -%}
                  {{ country.name }} ({{ country.currency.iso_code }}
                  {{ country.currency.symbol }})
                </button>
              </li>
            {%- endfor -%}
          </ul>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% style %}
  .shopify-section-{{ section.id }} {
    padding-top: {{ mobile_padding_top }}px;
    padding-bottom: {{ mobile_padding_bottom }}px;
  }

    @media (min-width: 768px) {
    .shopify-section-{{ section.id }} {
      padding-top: {{ tab_padding_top }}px;
      padding-bottom: {{ tab_padding_bottom }}px;
    }
  }

    @media (min-width: 992px) {
    .shopify-section-{{ section.id }} {
      padding-top: {{ laptop_padding_top }}px;
      padding-bottom: {{ laptop_padding_bottom }}px;
    }
  }

    @media (min-width: 1400px) {
    .shopify-section-{{ section.id }} {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
    }
  }
{% endstyle %}

<script src="{{ 'announcement-bar.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.announcement_bar.name",
  "tag": "section",
  "class": "nv-section-announcement-bar",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "t:common.general.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.announcement_bar.settings.color_scheme.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:common.padding_top.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:common.padding_bottom.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.announcement_bar.settings.autoplay.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:sections.announcement_bar.settings.autoplay_speed.label",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5,
      "info": "t:sections.announcement_bar.settings.autoplay_speed.info",
      "visible_if": "{{ section.settings.autoplay == true }}"
    },
    {
      "type": "header",
      "content": "t:sections.announcement_bar.settings.bar_content_heading.content"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "t:sections.announcement_bar.settings.contact_text.label",
      "default": "t:sections.announcement_bar.settings.contact_text.default"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "t:sections.announcement_bar.settings.contact_email.label",
      "info": "t:sections.announcement_bar.settings.contact_email.info"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "t:sections.announcement_bar.settings.show_country_selector.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "announcement",
      "name": "t:sections.announcement_bar.blocks.announcement.name",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.announcement_bar.blocks.announcement.settings.text.label",
          "default": "t:sections.announcement_bar.blocks.announcement.settings.text.default",
          "info": "t:sections.announcement_bar.blocks.announcement.settings.text.info"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:sections.announcement_bar.blocks.announcement.settings.url.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement_bar.presets.announcement_bar.name",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "t:sections.announcement_bar.presets.block.settings.text_one"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "t:sections.announcement_bar.presets.block.settings.text_two"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
