
<div
  class="sop-announcement-bar sop-container color-{{ section.settings.color_scheme }}"
  role="region"
  {% comment %} aria-label="{{ 'sections.announcement_bar.label' | t }}" {% endcomment %}
  aria-label="Announcement Bar"
>
  <div class="sop-announcement-bar-wrapper">
    {%- comment -%} LEFT — contact info (laptop only) {%- endcomment -%}
    <div class="sop-announcement-bar-left" aria-hidden="true">
      {%- if section.settings.contact_text != blank -%}
        <span class="sop-announcement-bar-contact">
          {{ section.settings.contact_text }}
        </span>
      {%- endif -%}
    </div>

    {%- comment -%} CENTRE — rotating messages {%- endcomment -%}
    <div class="sop-announcement-bar-center">
      <button
        class="sop-announcement-bar-arrow sop-announcement-bar-arrow--prev"
        aria-label="Previous announcement"
        {% if section.blocks.size <= 1 %}
          hidden
        {% endif %}
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8.75 16.25L2.5 10L8.75 3.75M2.5 10H17.5" stroke="white" stroke-opacity="0.9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="sop-announcement-bar-slider">
        {%- for block in section.blocks -%}
          <div class="swiper-slide sop-announcement-bar-slide" {{ block.shopify_attributes }}>
            <p>
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}" class="sop-announcement-bar-link">
                  {{ block.settings.text | escape }}
                </a>
              {%- else -%}
                {{ block.settings.text | escape }}
              {%- endif -%}
            </p>
          </div>
        {%- endfor -%}
      </div>

      <button
        class="sop-announcement-bar-arrow sop-announcement-bar-arrow--next"
        aria-label="Next announcement"
        {% if section.blocks.size <= 1 %}
          hidden
        {% endif %}
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M11.25 16.25L17.5 10L11.25 3.75M17.5 10H2.5" stroke="white" stroke-opacity="0.9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} RIGHT — locale/currency selector (laptop only) {%- endcomment -%}
    <div class="sop-announcement-bar-right" aria-hidden="true">
      {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
        <div class="sop-announcement-bar-locale">
          {%- form 'localization', id: 'sop-country-form-header' -%}
            <button
              type="button"
              class="sop-announcement-bar-locale-btn"
              aria-expanded="false"
              aria-controls="sop-locale-panel"
            >
              {{ localization.country.name }} | ({{ localization.country.currency.iso_code }}
              {{ localization.country.currency.symbol }})
              <span class="sop-announcement-bar-chevron" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M19.5 8.25L12 15.75L4.5 8.25" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
            <ul
              id="sop-country-list"
              class="sop-announcement-bar__country-list"
              role="list"
              hidden
            >
              {%- for country in localization.available_countries -%}
                <li role="listitem">
                  <button
                    type="submit"
                    name="country_code"
                    value="{{ country.iso_code }}"
                    class="sop-announcement-bar-country-option"
                  >
                    {{ country.name }}
                    ({{ country.currency.iso_code }}
                    {{ country.currency.symbol }})
                  </button>
                </li>
              {%- endfor -%}
            </ul>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>
  {% comment %} Panel {% endcomment %}
  <div id="sop-locale-panel" class="sop-locale-panel" hidden>
    <div class="sop-locale-panel-inner">
      <!-- Language Row -->
      <button type="button" class="sop-locale-row" id="sop-lang-btn">
        <span class="sop-locale-row-label">Language</span>
        <span class="sop-locale-row-value">
          English
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8.25 4.5L15.75 12L8.25 19.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg> 
        </span>
      </button>

      <!-- Currency Row -->
      {%- form 'localization', id: 'sop-country-form-panel' -%}
        <button type="button" class="sop-locale-row" id="sop-currency-btn">
          <span class="sop-locale-row-label">Currency</span>
          <span class="sop-locale-row-value">
            {{ localization.country.currency.iso_code }}
            ({{ localization.country.currency.symbol }})
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M8.25 4.5L15.75 12L8.25 19.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
      {%- endform -%}
      <div class="sop-locale-row-empty"></div>
    </div>
     
  </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
      const slides = document.querySelectorAll('.sop-announcement-bar-slide');
      const nextBtn = document.querySelector('.sop-announcement-bar-arrow--next');
      const prevBtn = document.querySelector('.sop-announcement-bar-arrow--prev');

      if (!slides.length) return;

      let current = 0;
      let autoplay;

      slides[current].classList.add('is-active');

      function goToSlide(nextIndex) {
        if (nextIndex === current) return;

        const currentSlide = slides[current];
        const nextSlide = slides[nextIndex];

        currentSlide.classList.remove('is-active');
        currentSlide.classList.add('is-exit');

        nextSlide.classList.add('is-active');

        setTimeout(() => {
          currentSlide.classList.remove('is-exit');
        }, 600);

        current = nextIndex;
      }

      function nextSlide() {
        let next = current + 1;

        if (next >= slides.length) {
          next = 0;
        }

        goToSlide(next);
      }

      function prevSlide() {
        let prev = current - 1;

        if (prev < 0) {
          prev = slides.length - 1;
        }

        goToSlide(prev);
      }

      /* Next Arrow */
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          nextSlide();
          restartAutoplay();
        });
      }

      /* Prev Arrow */
      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          prevSlide();
          restartAutoplay();
        });
      }

      /* Autoplay */
      {% if section.settings.autoplay %}
        function startAutoplay() {
          autoplay = setInterval(nextSlide, {{ section.settings.autoplay_speed | times: 1000 }});
        }

        function restartAutoplay() {
          clearInterval(autoplay);
          startAutoplay();
        }

        startAutoplay();
      {% endif %}


      const localeBtn = document.querySelector('.sop-announcement-bar-locale-btn');
      const localePanel = document.getElementById('sop-locale-panel');

  if (localeBtn && localePanel) {
    localeBtn.addEventListener('click', function () {
      const isOpen = localeBtn.getAttribute('aria-expanded') === 'true';
      localeBtn.setAttribute('aria-expanded', String(!isOpen));
      localePanel.hidden = isOpen;
    });

    // Close panel when clicking outside
    document.addEventListener('click', function (e) {
      if (!localeBtn.contains(e.target) && !localePanel.contains(e.target)) {
        localeBtn.setAttribute('aria-expanded', 'false');
        localePanel.hidden = true;
      }
    });
  }
    });
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "sop-section-announcement-bar",
  "limit": 1,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact info",
      "default": "Contact us: hello@demo.com"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country/currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play announcements",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Auto-play speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5,
      "info": "Only applies when auto-play is enabled"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message",
          "default": "Save upto 60% with code RICO26"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [{ "type": "announcement" }]
    }
  ]
}
{% endschema %}
