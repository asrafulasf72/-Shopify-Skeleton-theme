{% liquid
  assign layout_class = section.settings.layout
%}

<section
  class="image-with-text image-with-text--{{ layout_class }}"
  aria-labelledby="image-with-text-{{ section.id }}-heading"
>
  <div class="image-with-text__inner">
    <div class="image-with-text__media">
      {% if section.settings.image %}
        {% render 'responsive-image',
          image: section.settings.image,
          alt: section.settings.image_alt,
          decorative: false,
          class: 'image-with-text__image responsive-image',
          sizes: '(min-width: 1024px) 50vw, 100vw'
        %}
      {% else %}
        <div class="image-with-text__placeholder" role="img" aria-label="{{ 'sections.image_with_text.placeholder_alt' | t | escape }}">
          {{ 'sections.image_with_text.placeholder' | t | escape }}
        </div>
      {% endif %}
    </div>

    <div class="image-with-text__content">
      <header class="image-with-text__header">
        {% if section.settings.subheading != blank %}
          <p class="image-with-text__eyebrow">{{ section.settings.subheading | escape }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 id="image-with-text-{{ section.id }}-heading" class="image-with-text__heading">
            {{ section.settings.heading | escape }}
          </h2>
        {% else %}
          <h2 id="image-with-text-{{ section.id }}-heading" class="image-with-text__heading">
            {{ 'sections.image_with_text.default_heading' | t | escape }}
          </h2>
        {% endif %}
      </header>

      {% if section.settings.body != blank %}
        <div class="image-with-text__body">
          {{ section.settings.body }}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <div class="image-with-text__actions">
          {% render 'accessible-button',
            label: section.settings.button_label,
            url: section.settings.button_url,
            style: 'image-with-text__button',
            aria_description: section.settings.button_aria_description,
            description_id: 'image-with-text-' | append: section.id | append: '-button-desc'
          %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .image-with-text {
    padding: 3rem 1.5rem;
  }

  .image-with-text__inner {
    max-width: 72rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .image-with-text__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }

    .image-with-text--image_left .image-with-text__media {
      order: 0;
    }

    .image-with-text--image_left .image-with-text__content {
      order: 1;
    }

    .image-with-text--image_right .image-with-text__media {
      order: 1;
    }

    .image-with-text--image_right .image-with-text__content {
      order: 0;
    }
  }

  .image-with-text__media {
    width: 100%;
  }

  .image-with-text__image {
    border-radius: 0.75rem;
    object-fit: cover;
  }

  .image-with-text__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    border-radius: 0.75rem;
    background: repeating-linear-gradient(
      -45deg,
      rgba(0, 0, 0, 0.05),
      rgba(0, 0, 0, 0.05) 10px,
      rgba(0, 0, 0, 0.02) 10px,
      rgba(0, 0, 0, 0.02) 20px
    );
    color: rgba(0, 0, 0, 0.6);
    font-size: 0.875rem;
    text-align: center;
    padding: 1rem;
  }

  .image-with-text__content {
    text-align: left;
  }

  .image-with-text__eyebrow {
    margin: 0 0 0.5rem 0;
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .image-with-text__heading {
    margin: 0;
    font-size: clamp(1.75rem, 1.3rem + 1.5vw, 2.25rem);
    line-height: 1.1;
  }

  .image-with-text__body {
    margin-top: 1rem;
  }

  .image-with-text__actions {
    margin-top: 1.5rem;
  }

  .image-with-text__button {
    font-weight: 600;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.image_with_text.name",
  "tag": "section",
  "class": "image-with-text-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.image_with_text.settings.header.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image_with_text.settings.image.label"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "t:sections.image_with_text.settings.image_alt.label",
      "info": "t:sections.image_with_text.settings.image_alt.info"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.image_with_text.settings.layout.label",
      "default": "image_left",
      "options": [
        {
          "value": "image_left",
          "label": "t:sections.image_with_text.settings.layout.options.image_left"
        },
        {
          "value": "image_right",
          "label": "t:sections.image_with_text.settings.layout.options.image_right"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text.settings.text_header.content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.image_with_text.settings.subheading.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.image_with_text.settings.heading.label",
      "default": "Image with text"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:sections.image_with_text.settings.body.label"
    },
    {
      "type": "header",
      "content": "t:sections.image_with_text.settings.button_header.content"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.image_with_text.settings.button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:sections.image_with_text.settings.button_url.label"
    },
    {
      "type": "text",
      "id": "button_aria_description",
      "label": "t:sections.image_with_text.settings.button_aria_description.label",
      "info": "t:sections.image_with_text.settings.button_aria_description.info"
    }
  ],
  "presets": [
    {
      "name": "t:sections.image_with_text.presets.default.name",
      "category": "t:sections.image_with_text.presets.default.category"
    }
  ]
}
{% endschema %}