
<div class="pw-page shopify-section-{{ section.id }} color-{{ section.settings.color_schemes }}">
  <header class="pw-header">
    <a href="{{ routes.root_url }}" class="pw-logo" aria-label="{{ shop.name }}">
      {%- if shop.logo -%}
        <img
          class="pw-logo__img"
          src="{{ shop.logo | image_url: height: 72 }}"
          alt="{{ shop.name }}"
          width="{{ shop.logo.width }}"
          height="{{ shop.logo.height }}"
          loading="eager"
        >
      {%- else -%}
        <span class="pw-logo__text">
          {{- shop.name -}}
          <span class="pw-logo__sup">®</span>
        </span>
      {%- endif -%}
    </a>

    <button
      class="pw-header-cta"
      id="pw-open-btn"
      type="button"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-controls="pw-modal-overlay"
    >
      {{- section.settings.header_cta_label | default: 'Enter storefront password' -}}
      <svg
        class="pw-lock-icon"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <rect x="4.5" y="10.5" width="15" height="11" stroke="currentColor" stroke-width="1.5"/>
        <path d="M8 10.5V7a4 4 0 1 1 8 0v3.5" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </button>
  </header>

  <main class="pw-main" id="main-content">
    <div class="pw-card">
      <div class="pw-card__text">
        <h1 class="pw-card__title">
          {%- if shop.password_message and shop.password_message != blank -%}
            {{ shop.password_message }}
          {%- else -%}
            {{ section.settings.heading | default: 'Opening soon!' }}
          {%- endif -%}
        </h1>
        <p class="pw-card__subtitle">
          {{ section.settings.subheading | default: 'Be the first one to know when we open!' }}
        </p>
      </div>

      {%- form 'customer', id: 'subscribe-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="pw-success" role="status" aria-live="polite">
            <svg
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <circle cx="9" cy="9" r="8.25" stroke="#3a7d3a" stroke-width="1.5"/>
              <path d="M5.25 9l2.5 2.5 5-5" stroke="#3a7d3a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ 'password.subscribe_success' | t | default: "You're on the list! We'll let you know when we open." }}
          </div>
        {%- else -%}
          <div class="pw-subscribe-form">
            <label for="subscribe-email" class="visually-hidden">
              {{- 'password.subscribe_email_placeholder' | t | default: 'Email address' -}}
            </label>
            <input
              class="pw-input"
              type="email"
              name="contact[email]"
              id="subscribe-email"
              autocomplete="email"
              placeholder="{{ 'password.subscribe_email_placeholder' | t | default: 'Email address...' }} *"
              required
            >
            <button type="submit" class="pw-btn nv-btn-bg nv-btn-animation">
              {{ section.settings.subscribe_button_label | default: 'Subscribe' }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </main>

  <div
    class="pw-overlay"
    id="pw-modal-overlay"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pw-modal-title"
  >
    <div class="pw-modal" id="pw-modal-box">
      <button
        class="pw-modal__close"
        id="pw-close-btn"
        type="button"
        aria-label="{{ 'general.accessibility.close' | t | default: 'Close' }}"
      >
        <svg
          width="12"
          height="12"
          viewBox="0 0 12 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </button>

      <div class="pw-modal__inner">
        <h2 class="pw-modal__title" id="pw-modal-title">
          {{ section.settings.header_cta_label | default: 'Enter storefront password' }}
        </h2>

        {%- form 'storefront_password', id: 'storefront-password-form' -%}
          <div class="pw-modal__form-row">
            <div class="pw-input-wrap">
              <label for="password-input" class="visually-hidden">
                {{- 'password.login_form.password_placeholder' | t | default: 'Your password' -}}
              </label>
              <input
                class="pw-input"
                type="password"
                name="password"
                id="password-input"
                autocomplete="current-password"
                placeholder="{{ 'password.login_form.password_placeholder' | t | default: 'Your password' }} *"
                {%- if form.errors %}
                  aria-describedby="pw-form-error" aria-invalid="true"
                {%- endif %}
                required
              >
              {%- if form.errors -%}
                <p class="pw-error" role="alert" id="pw-form-error">
                  {{ 'password.login_form.error' | t | default: 'Incorrect password. Please try again.' }}
                </p>
              {%- endif -%}
            </div>
            <button type="submit" class="pw-btn nv-btn-bg nv-btn-animation">
              {{ section.settings.enter_button_label | default: 'Enter' }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>





