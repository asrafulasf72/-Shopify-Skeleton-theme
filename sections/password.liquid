{% stylesheet %}
  .pw-page *,
  .pw-page *::before,
  .pw-page *::after {
    box-sizing: border-box;
  }

  html,
  body {
    height: 100%;
    margin: 0;
  }

  .pw-page {
    background-color: var(--nv-background);
    color: var(--nv-text);
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    min-height: 100vh;
    position: relative;
  }

  /* ── Header ── */
  .pw-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 76px;
    border-bottom: 1px solid var(--nv-text);
    background-color: var(--nv-background);
    z-index: 100;
    display: flex;
    align-items: center;
    padding: 0 80px;
    justify-content: space-between;
    gap: 16px;
  }

  .pw-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--nv-text);
    line-height: 1;
    min-width: 0;
    flex-shrink: 1;
  }

  .pw-logo__img {
    display: block;
    max-height: 34px;
    width: auto;
    object-fit: contain;
  }

  .pw-logo__text {
    font-size: 20px;
    letter-spacing: 0;
    white-space: nowrap;
    line-height: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pw-logo__sup {
    font-size: 10px;
    vertical-align: super;
    line-height: 0;
  }

  .pw-header-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    background-color: none;
    border: none;
    font-size: 14px;
    line-height: 1.4;
    color: var(--nv-text);
    padding: 0;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .pw-header-cta:hover {
    opacity: 0.6;
  }

  .pw-lock-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--nv-text);
  }

  /* ── Main ── */
  .pw-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 76px;
    min-height: 100dvh;
    min-height: 100vh;
    padding-left: 20px;
    padding-right: 20px;
  }

  /* ── Card (email subscribe) ── */
  .pw-card {
    width: 918px;
    max-width: calc(100vw - 40px);
    background-color: var(--nv-foreground);
    box-shadow: 0px -1px 4px rgba(0, 0, 0, 0.1), 0px 1px 4px rgba(0, 0, 0, 0.1);
    padding: 60px 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 70px;
  }

  .pw-card__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    width: 326px;
    max-width: 100%;
  }

  .pw-card__title {
    font-size: 32px;
    line-height: 40px;
    color: var(--nv-text);
    margin: 0;
    width: 100%;
  }

  .pw-card__subtitle {
    font-size: 14px;
    line-height: 140%;
    color: var(--nv-text);
    margin: 0;
    width: 100%;
  }

  /* ── Subscribe form ── */
  .pw-subscribe-form {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
    gap: 12px;
    width: 561px;
    max-width: 100%;
  }

  .pw-subscribe-form .pw-input {
    width: 400px;
    height: 52px;
    padding: 16px 12px;
    flex-shrink: 1;
    min-width: 0;
  }

  .pw-subscribe-form .pw-btn {
    width: 149px;
    height: 52px;
    padding: 16px 32px;
    flex-shrink: 0;
  }

  /* ── Shared input base ── */
  .pw-input {
    font-size: 14px;
    color: var(--nv-text);
    background-color: var(--nv-background);
    border: 1px solid var(--nv-text);
    padding: 16px 12px;
    height: 52px;
    outline: none;
    flex: 1;
    min-width: 0;
    border-radius: 0;
    -webkit-appearance: none;
    appearance: none;
  }

  .pw-input::placeholder {
    color: var(--nv-foreground-text);
  }

  .pw-btn {
    font-size: 14px;
    line-height: 140%;
    color: var(--nv-primary-btn-text);
    background-color: var(--nv-primary-btn-background);
    border: 1px solid var(--nv-text);
    padding: 16px 32px;
    height: 52px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    white-space: nowrap;
    width: fit-content;
  }

  /* ── Success ── */
  .pw-success {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--nv-text);
    background-color: #f0f7f0;
    border: 1px solid #c3ddc3;
    padding: 14px 20px;
    max-width: 561px;
    width: 100%;
  }

  .pw-success svg {
    flex-shrink: 0;
  }

  /* ── Overlay ── */
  .pw-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(28, 28, 28, 0.3);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .pw-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Password modal ── */
  .pw-modal {
    position: relative;
    width: 918px;
    max-width: calc(100vw - 40px);
    background-color: var(--nv-foreground);
    box-shadow: 0px -1px 4px rgba(0, 0, 0, 0.1), 0px 1px 4px rgba(0, 0, 0, 0.1);
    padding: 60px 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    transform: translateY(12px);
    transition: transform 0.22s ease;
  }

  .pw-overlay.is-open .pw-modal {
    transform: translateY(0);
  }

  .pw-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 24px;
    height: 24px;
    background-color: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s ease;
  }

  .pw-modal__close:hover {
    opacity: 0.5;
  }

  .pw-modal__close:focus-visible {
    outline: 2px solid var(--nv-text);
    outline-offset: 3px;
  }

  /* ── Inner content column (442px) ── */
  .pw-modal__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    width: 442px;
    max-width: 100%;
  }

  .pw-modal__title {
    font-size: 24px;
    line-height: 30px;
    text-align: center;
    color: var(--nv-text);
    margin: 0;
    width: 100%;
  }

  /* ── Password form row ── */
  .pw-modal__form-row {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: flex-start;
    gap: 12px;
    width: 442px;
    max-width: 100%;
  }

  .pw-modal__form-row .pw-btn {
    width: 110px;
    height: 52px;
    padding: 16px 32px;
    flex-shrink: 0;
  }

  /* ── Input + error wrapper ── */
  .pw-input-wrap {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
    gap: 6px;
  }

  .pw-input-wrap .pw-input {
    width: 100%;
    height: 52px;
    padding: 16px 12px;
    color: var(--nv-text);
  }

  .pw-input-wrap .pw-input::placeholder {
    color: var(--nv-foreground-text);
  }

  /* ── Error message ── */
  .pw-error {
    font-size: 12px;
    line-height: 1.4;
    color: #c0392b;
    margin: 0;
    padding-left: 2px;
  }

  /* ── Store owner link ── */
  .pw-modal__owner-link {
    font-size: 14px;
    line-height: 140%;
    text-align: center;
    color: var(--nv-text);
    margin: 0;
    width: 100%;
  }

  .pw-modal__owner-link a {
    color: var(--nv-text);
    text-decoration: underline;
    transition: opacity 0.15s ease;
  }

  .pw-modal__owner-link a:hover {
    opacity: 0.6;
  }

  /* ── Breakpoints ── */
  @media (max-width: 980px) {
    .pw-header {
      padding: 0 32px;
    }
    .pw-card {
      width: 100%;
      padding: 60px 32px;
    }
    .pw-modal {
      padding: 60px 32px;
    }
  }

  @media (max-width: 768px) {
    .pw-header {
      padding: 0 24px;
    }
    .pw-card {
      padding: 48px 24px;
      gap: 40px;
    }
    .pw-modal {
      padding: 48px 24px;
      gap: 32px;
    }
    .pw-subscribe-form {
      flex-direction: column;
      gap: 10px;
      width: 100%;
    }
    .pw-subscribe-form .pw-input,
    .pw-subscribe-form .pw-btn {
      width: 100%;
      height: 52px;
    }
    .pw-modal__inner {
      width: 100%;
    }
    .pw-modal__form-row {
      width: 100%;
      flex-direction: column;
      gap: 10px;
    }
    .pw-modal__form-row .pw-btn {
      width: 100%;
      height: 52px;
    }
    .pw-input-wrap .pw-input {
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .pw-header {
      height: 56px;
      padding: 0 20px;
    }
    .pw-main {
      padding-top: 56px;
      padding-left: 16px;
      padding-right: 16px;
    }
    .pw-logo__text {
      font-size: 16px;
    }
    .pw-logo__img {
      max-height: 28px;
    }
    .pw-header-cta {
      font-size: 12px;
    }
    .pw-header-cta .pw-lock-icon {
      width: 16px;
      height: 16px;
    }
    .pw-card {
      padding: 40px 16px;
      gap: 32px;
    }
    .pw-card__title {
      font-size: 24px;
      line-height: 30px;
    }
    .pw-card__text {
      width: 100%;
    }
    .pw-modal {
      padding: 40px 16px 32px;
      gap: 24px;
      max-width: calc(100vw - 32px);
    }
    .pw-modal__title {
      font-size: 18px;
      line-height: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pw-overlay,
    .pw-modal,
    .pw-btn,
    .pw-modal__close,
    .pw-header-cta,
    .pw-input {
      transition: none;
    }
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
{% endstylesheet %}

<div class="pw-page shopify-section-{{ section.id }} color-{{ section.settings.color_schemes }}">
  <header class="pw-header">
    <a href="{{ routes.root_url }}" class="pw-logo" aria-label="{{ shop.name }}">
      {%- if shop.logo -%}
        <img
          class="pw-logo__img"
          src="{{ shop.logo | image_url: height: 72 }}"
          alt="{{ shop.name }}"
          width="{{ shop.logo.width }}"
          height="{{ shop.logo.height }}"
          loading="eager"
        >
      {%- else -%}
        <span class="pw-logo__text">
          {{- shop.name -}}
          <span class="pw-logo__sup">®</span>
        </span>
      {%- endif -%}
    </a>

    <button
      class="pw-header-cta"
      id="pw-open-btn"
      type="button"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-controls="pw-modal-overlay"
    >
      {{- section.settings.header_cta_label | default: 'Enter storefront password' -}}
      <svg
        class="pw-lock-icon"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <rect x="4.5" y="10.5" width="15" height="11" stroke="currentColor" stroke-width="1.5"/>
        <path d="M8 10.5V7a4 4 0 1 1 8 0v3.5" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </button>
  </header>

  <main class="pw-main" id="main-content">
    <div class="pw-card">
      <div class="pw-card__text">
        <h1 class="pw-card__title">
          {%- if shop.password_message and shop.password_message != blank -%}
            {{ shop.password_message }}
          {%- else -%}
            {{ section.settings.heading | default: 'Opening soon!' }}
          {%- endif -%}
        </h1>
        <p class="pw-card__subtitle">
          {{ section.settings.subheading | default: 'Be the first one to know when we open!' }}
        </p>
      </div>

      {%- form 'customer', id: 'subscribe-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div class="pw-success" role="status" aria-live="polite">
            <svg
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <circle cx="9" cy="9" r="8.25" stroke="#3a7d3a" stroke-width="1.5"/>
              <path d="M5.25 9l2.5 2.5 5-5" stroke="#3a7d3a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ 'password.subscribe_success' | t | default: "You're on the list! We'll let you know when we open." }}
          </div>
        {%- else -%}
          <div class="pw-subscribe-form">
            <label for="subscribe-email" class="visually-hidden">
              {{- 'password.subscribe_email_placeholder' | t | default: 'Email address' -}}
            </label>
            <input
              class="pw-input"
              type="email"
              name="contact[email]"
              id="subscribe-email"
              autocomplete="email"
              placeholder="{{ 'password.subscribe_email_placeholder' | t | default: 'Email address...' }} *"
              required
            >
            <button type="submit" class="pw-btn nv-btn-bg nv-btn-animation">
              {{ section.settings.subscribe_button_label | default: 'Subscribe' }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </main>

  <div
    class="pw-overlay"
    id="pw-modal-overlay"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pw-modal-title"
  >
    <div class="pw-modal" id="pw-modal-box">
      <button
        class="pw-modal__close"
        id="pw-close-btn"
        type="button"
        aria-label="{{ 'general.accessibility.close' | t | default: 'Close' }}"
      >
        <svg
          width="12"
          height="12"
          viewBox="0 0 12 12"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </button>

      <div class="pw-modal__inner">
        <h2 class="pw-modal__title" id="pw-modal-title">
          {{ section.settings.header_cta_label | default: 'Enter storefront password' }}
        </h2>

        {%- form 'storefront_password', id: 'storefront-password-form' -%}
          <div class="pw-modal__form-row">
            <div class="pw-input-wrap">
              <label for="password-input" class="visually-hidden">
                {{- 'password.login_form.password_placeholder' | t | default: 'Your password' -}}
              </label>
              <input
                class="pw-input"
                type="password"
                name="password"
                id="password-input"
                autocomplete="current-password"
                placeholder="{{ 'password.login_form.password_placeholder' | t | default: 'Your password' }} *"
                {%- if form.errors %}
                  aria-describedby="pw-form-error" aria-invalid="true"
                {%- endif %}
                required
              >
              {%- if form.errors -%}
                <p class="pw-error" role="alert" id="pw-form-error">
                  {{ 'password.login_form.error' | t | default: 'Incorrect password. Please try again.' }}
                </p>
              {%- endif -%}
            </div>
            <button type="submit" class="pw-btn nv-btn-bg nv-btn-animation">
              {{ section.settings.enter_button_label | default: 'Enter' }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% javascript %}
  (function () {
    'use strict';

    let overlay = document.getElementById('pw-modal-overlay');
    let openBtn = document.getElementById('pw-open-btn');
    let closeBtn = document.getElementById('pw-close-btn');
    let modal = document.getElementById('pw-modal-box');

    function getFocusable() {
      return Array.from(
        modal.querySelectorAll(
          'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      );
    }

    function openModal() {
      overlay.classList.add('is-open');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      setTimeout(function () {
        let target = document.getElementById('password-input') || closeBtn;
        target.focus();
      }, 60);
    }

    function closeModal() {
      overlay.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      openBtn.focus();
    }

    openBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);

    overlay.addEventListener('click', function (e) {
      if (e.target === overlay) closeModal();
    });

    document.addEventListener('keydown', function (e) {
      if (!overlay.classList.contains('is-open')) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        closeModal();
        return;
      }

      if (e.key === 'Tab') {
        let focusable = getFocusable();
        if (!focusable.length) return;
        let first = focusable[0];
        var last = focusable[focusable.length - 1];

        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });

    let errEl = document.getElementById('pw-form-error');
    if (errEl) {
      openModal();
      let pwInput = document.getElementById('password-input');
      if (pwInput) {
        pwInput.addEventListener(
          'input',
          function () {
            errEl.style.display = 'none';
            pwInput.removeAttribute('aria-invalid');
          },
          { once: true }
        );
      }
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.password.name",
  "settings": [
    {
      "type": "header",
      "content": "t:common.general.content"
    },
    {
      "type": "color_scheme",
      "id": "color_schemes",
      "label": "t:sections.password.settings.color_schemes.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.password.settings.heading.label",
      "default": "t:sections.password.settings.heading.default"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.password.settings.subheading.label",
      "default": "t:sections.password.settings.subheading.default"
    },
    {
      "type": "text",
      "id": "subscribe_button_label",
      "label": "t:sections.password.settings.subscribe_button_label.label",
      "default": "t:sections.password.settings.subscribe_button_label.default"
    },
    {
      "type": "text",
      "id": "header_cta_label",
      "label": "t:sections.password.settings.header_cta_label.label",
      "default": "t:sections.password.settings.header_cta_label.default"
    },
    {
      "type": "text",
      "id": "enter_button_label",
      "label": "t:sections.password.settings.enter_button_label.label",
      "default": "t:sections.password.settings.enter_button_label.default"
    }
  ]
}
{% endschema %}