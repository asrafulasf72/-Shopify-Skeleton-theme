{% comment %}
  Section : collection-product-grid.liquid
{% endcomment %}

{%- liquid
  assign col           = section.settings.collection
  assign limit         = section.settings.products_to_show | default: 8
  assign heading       = section.settings.title
  assign show_heading  = section.settings.show_heading
  assign columns_desk  = section.settings.columns_desktop | default: 4
  assign bg_color      = section.settings.bg_color | default: '#f0eeea'
-%}

<section
  class="cpg"
  id="cpg-{{ section.id }}"
  style="
    background: {{ bg_color }};
    --cpg-cols: {{ columns_desk }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="cpg__inner">

    {%- if show_heading and heading != blank -%}
      <div class="cpg__header">
        <h2 class="cpg__heading">{{ heading }}</h2>
      </div>
    {%- endif -%}

    {%- if col != blank -%}
      <ul class="cpg__grid" role="list">
        {%- for product in col.products limit: limit -%}
          <li class="cpg__item">
            {%- render 'product-card3', product: product -%}
          </li>
        {%- else -%}
          <li style="grid-column:1/-1; text-align:center; padding:2rem; color:#9ca3af;">
            No products found.
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p style="text-align:center; padding:2rem; color:#9ca3af;">
        Please select a collection in the section settings.
      </p>
    {%- endif -%}
  </div>
</section>

{% style %}

/* ── Section / Grid ─────────────────────────── */
.cpg { font-family: Arial, sans-serif; }
.cpg__inner {
  max-width: 1300px;
  margin-inline: auto;
  padding-inline: clamp(1rem, 4vw, 2.5rem);
}
.cpg__header { margin-bottom: clamp(1.25rem, 3vw, 2rem); }
.cpg__heading {
  font-size: clamp(1.3rem, 3.5vw, 2.1rem);
  font-weight: 700;
  color: #111827;
  margin: 0;
}
.cpg__grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(1, 1fr);
}
@media (min-width: 768px) {
  .cpg__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1100px) {
  .cpg__grid { grid-template-columns: repeat(var(--cpg-cols, 4), 1fr); gap: 16px; }
}

/* ── RESET ──────────────────────────────────── */
.pc_card * { margin: 0; padding: 0; box-sizing: border-box; }

/* ── CARD ───────────────────────────────────── */
.pc_card {
  position: relative;
  overflow: hidden;
  width: 100%;
  background: #F2F2F2;
  /* border: 1px solid #e5e7eb; */
  display: flex;
  flex-direction: column;
  font-family: Arial, sans-serif;
}

/* ── HEADER ─────────────────────────────────── */
.pc_card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16px 16px 0;
}
.title {
  font-size: 14px;
  font-weight: 500;
  color: #111827;
}
.price {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}
.old-price {
  font-size: 12px;
  color: #9ca3af;
  text-decoration: line-through;
}
.new-price {
  font-size: 12px;
  font-weight: 500;
  color: #111827;
}

/* ── BADGE ──────────────────────────────────── */
.badge {
  background: #111827;
  color: white;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 6px 12px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ── IMAGE ──────────────────────────────────── */
.image-box {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32px 24px;
}
.image-box a { display: block; }
.image-box img {
  width: 100%;
  max-width: 280px;
  height: auto;
  object-fit: contain;
}
.img-placeholder {
  width: 280px;
  height: 200px;
  background: #e5e7eb;
}

/* ── DOTS ───────────────────────────────────── */
.dots {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  position: relative;
  top: 20px;
}
.dots span {
  width: 32px;
  height: 2px;
  background: #d1d5db;
  border-radius: 999px;
}
.dots .active { background: #111827; }

/* ── BOTTOM AREA ────────────────────────────── */
.bottom-area {
  position: relative;
  transform: translateY(60px);
  transition: transform 0.35s ease, opacity 0.35s ease;
}
.bottom-inner {
  transform: translateY(100%);
  opacity: 0;
  transition: transform 0.35s ease, opacity 0.35s ease;
}
.pc_card:hover .bottom-area {
  transform: translateY(0);
  opacity: 1;
}
.pc_card:hover .bottom-inner {
  transform: translateY(0);
  opacity: 1;
}

/* ── NAV ────────────────────────────────────── */
.pc_nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px 16px;
}
.nav-btn {
  width: 36px;
  height: 36px;
  border: 1px solid #0f0f0f;
  background: transparent;
  cursor: pointer;
  font-size: 16px;
  color: #6b7280;
  transition: all 0.2s;
}
.nav-btn:hover { color: #f6f8fc; }

/* ── ACTIONS ────────────────────────────────── */
.actions { display: flex; }
.action-btn {
  flex: 1;
  padding: 14px 0;
  font-size: 12px;
  font-weight: 500;
  color: #111827;
  background: transparent;
  border: 1px solid #030303;
  cursor: pointer;
  transition: background 0.2s;
}
.action-btn:hover {
  background: #000000;
  color: white;
}
{% endstyle %}

{% schema %}
{
  "name": "Collection Product Grid",
  "tag": "section",
  "class": "section-cpg",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2, "max": 24, "step": 2,
      "default": 8
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#f0eeea"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0, "max": 120, "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0, "max": 120, "step": 4,
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Collection Product Grid",
      "settings": {
        "title": "Featured Products",
        "products_to_show": 8,
        "columns_desktop": "4"
      }
    }
  ]
}
{% endschema %}