{% comment %}
  Premium Custom 404 Section Template
  Designed to meet Figma 50/50 Desktop split layout guidelines and WCAG 2.1 AA Accessibility criteria.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/404
{% endcomment %}

{%- # Load Google Font 'Unbounded' cleanly -%}


<section class="nv-404-section" aria-label="Page not found route container">
  {%- # Breadcrumb nav element conforming perfectly to the design mockup -%}
  <nav class="nv-404-breadcrumb" aria-label="{{ 'general.accessibility.breadcrumb' | t }}">
    <a href="{{ routes.root_url }}" class="nv-404-breadcrumb-link">{{ 'general.breadcrumbs.home' | t }}</a>
    <span class="nv-404-breadcrumb-separator" aria-hidden="true">•</span>
    <span class="nv-404-breadcrumb-current">{{ 'general.breadcrumbs.not_found' | t }}</span>
  </nav>

  {%- # 50/50 responsive side-by-side grid split -%}
  <div class="nv-404-grid">
    {%- # Left Column: Visual Asset -%}
    <div class="nv-404-visual-column">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag: class: 'nv-404-image', loading: 'eager', fetchpriority: 'high', alt: section.settings.image.alt
          | default: 'Page not found visual asset illustration'
        }}
      {%- else -%}
        {%- # Standard high-quality Shopify product fallback illustration, fully styled -%}
        {{ 'product-1' | placeholder_svg_tag: 'nv-404-placeholder-svg' }}
      {%- endif -%}
    </div>

    {%- # Right Column: Content Canvas -%}
    <div class="nv-404-content-column">
      {%- # Top Row Container: Description Announcement & CTA Button -%}
      <div class="nv-404-top-row">
        <p class="nv-404-announcement">
          {{ section.settings.announcement_text | escape }}
        </p>

        <a
          href="{{ section.settings.button_link | default: routes.root_url }}"
          class="nv-404-cta-button"
          aria-label="{{ section.settings.button_text | escape }}, return to main homepage store route"
        >
          {{ section.settings.button_text | escape }}
        </a>
      </div>

      {%- # Bottom Row Container: Primary h1 Title Heading & Numeric Status Code -%}
      <div class="nv-404-bottom-row">
        <h1 class="nv-404-title">
          {{ section.settings.subheadline_text | escape }}
        </h1>

        <span class="nv-404-status-code" aria-label="Error code: {{ section.settings.status_code_text }}">
          {{ section.settings.status_code_text | escape }}
        </span>
      </div>
    </div>
  </div>
</section>

