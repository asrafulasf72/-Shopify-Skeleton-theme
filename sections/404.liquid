{% comment %}
  Premium Custom 404 Section Template
  Designed to meet Figma 50/50 Desktop split layout guidelines and WCAG 2.1 AA Accessibility criteria.
  https://shopify.dev/docs/storefronts/themes/architecture/templates/404
{% endcomment %}

{%- # Load Google Font 'Unbounded' cleanly -%}
{% style %}
     .nv-404-section {
      width: 100%;
      padding: 24px 20px 120px 20px;
      box-sizing: border-box;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
  }
        /* Breadcrumb Navigation */
        .nv-404-breadcrumb {
          font-size: 18px;
          line-height: 1.2;
          display: flex;
          align-items: center;
          gap: 8px;
          color: {{ section.settings.text_color }};
        }

        .nv-404-breadcrumb-link {
          color: {{ section.settings.text_color }};
          text-decoration: none;
          transition: opacity 0.2s ease;
        }

        .nv-404-breadcrumb-link:hover {
          opacity: 0.7;
        }

        .nv-404-breadcrumb-separator {
          margin: 0 10px;
          opacity: 0.6;
        }

        .nv-404-breadcrumb-current {
          font-weight: 500;
        }

        /* Layout Grid - Mobile first stacked */
        .nv-404-grid {
          display: flex;
          flex-direction: column;
          gap: 32px;
        }

        /* Left Column: Visual Asset */
        .nv-404-visual-column {
          width: 100%;
          height: auto;
          aspect-ratio: 4 / 3;
          overflow: hidden;
          background-color: #f7f7f7;
          display: block;
          position: relative;
          box-sizing: border-box;
        }

        .nv-404-image {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
          transition: transform 0.3s ease;
        }

        .nv-404-placeholder-svg {
          width: 100%;
          height: 100%;
          background-color: #f7f7f7;
          fill: #a3a3a3;
          display: block;
          opacity: 0.85;
        }

        /* Right Column: Content Canvas */
        .nv-404-content-column {
          background-color: {{ section.settings.bg_color }};
          color: {{ section.settings.text_color }};
          display: flex;
          flex-direction: column;
          justify-content: space-between;
          gap: 48px;
          box-sizing: border-box;
        }

        /* Top Row Block */
        .nv-404-top-row {
          display: flex;
          flex-direction: column;
          gap: 24px;
          align-items: flex-start;
        }

        .nv-404-announcement {
          font-size: 20px;
          line-height: 28px;
          
          color: {{ section.settings.announcement_color }};
          margin: 0;
          max-width: 100%;
          letter-spacing: -0.01em;
        }

        /* CTA Button styles */
        .nv-404-cta-button {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          background-color: {{ section.settings.btn_bg_color }};
          color: {{ section.settings.btn_text_color }};
          border: 1.5px solid {{ section.settings.btn_bg_color }};
          padding: 16px 24px;
          font-size: 14px;
          line-height: 17px;
          font-weight: 500;
          text-decoration: none;
          text-align: center;
          cursor: pointer;
          transition: background-color 0.2s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.2s ease, opacity 0.2s ease;
          box-sizing: border-box;
        }

        .nv-404-cta-button:hover {
          opacity: 0.9;
        }

        .nv-404-cta-button:focus-visible {
          outline: 2px solid {{ section.settings.text_color }};
          outline-offset: 2px;
        }

        /* Bottom Row Block */
        .nv-404-bottom-row {
          display: flex;
          flex-direction: column;
          gap: 16px;
          align-items: flex-start;
        }

        .nv-404-title {
          font-size: clamp(38px, 7vw, 76px);
          line-height: 1.0;
          font-weight: 500;
          text-transform: capitalize;
          color: {{ section.settings.text_color }};
          margin: 0;
          letter-spacing: -0.02em;
          word-break: break-word;
          max-width: 480px;
        }

        .nv-404-status-code {
          font-size: clamp(48px, 8vw, 76px);
          line-height: 94px;
          
          color: {{ section.settings.text_color }};
          letter-spacing: -0.01em;
          margin: 0;
        }

        /* Desktop layout overrides (screens >= 990px) */
        @media (min-width: 990px) {


         .nv-404-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        margin-top: 70px;
        align-items: stretch;
        min-height: 44.375rem;
    }
          .nv-404-visual-column {
            height: 100%;
            aspect-ratio: auto;
          }

          .nv-404-content-column {
            padding: 0;
            gap: 0;
          }

          .nv-404-top-row {
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-start;
            gap: 30px;
          }

          .nv-404-announcement {
            font-size: 24px;
            line-height: 30px;
            max-width: 320px;
          }

          .nv-404-bottom-row {
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-end;
            gap: 30px;
          }

          .nv-404-status-code {
            line-height: 76px;
          }
        }
{% endstyle %}

<section class="nv-404-section" aria-label="Page not found route container">
  {%- # Breadcrumb nav element conforming perfectly to the design mockup -%}
  <nav class="nv-404-breadcrumb" aria-label="{{ 'general.accessibility.breadcrumb' | t }}">
    <a href="{{ routes.root_url }}" class="nv-404-breadcrumb-link">{{ 'general.breadcrumbs.home' | t }}</a>
    <span class="nv-404-breadcrumb-separator" aria-hidden="true">•</span>
    <span class="nv-404-breadcrumb-current">{{ 'general.breadcrumbs.not_found' | t }}</span>
  </nav>

  {%- # 50/50 responsive side-by-side grid split -%}
  <div class="nv-404-grid">
    {%- # Left Column: Visual Asset -%}
    <div class="nv-404-visual-column">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1000
          | image_tag: class: 'nv-404-image', loading: 'eager', fetchpriority: 'high', alt: section.settings.image.alt
          | default: 'Page not found visual asset illustration'
        }}
      {%- else -%}
        {%- # Standard high-quality Shopify product fallback illustration, fully styled -%}
        {{ 'product-1' | placeholder_svg_tag: 'nv-404-placeholder-svg' }}
      {%- endif -%}
    </div>

    {%- # Right Column: Content Canvas -%}
    <div class="nv-404-content-column">
      {%- # Top Row Container: Description Announcement & CTA Button -%}
      <div class="nv-404-top-row">
        <p class="nv-404-announcement">
          {{ section.settings.announcement_text | escape }}
        </p>

        <a
          href="{{ section.settings.button_link | default: routes.root_url }}"
          class="nv-404-cta-button"
          aria-label="{{ section.settings.button_text | escape }}, return to main homepage store route"
        >
          {{ section.settings.button_text | escape }}
        </a>
      </div>

      {%- # Bottom Row Container: Primary h1 Title Heading & Numeric Status Code -%}
      <div class="nv-404-bottom-row">
        <h1 class="nv-404-title">
          {{ section.settings.subheadline_text | escape }}
        </h1>

        <span class="nv-404-status-code" aria-label="Error code: {{ section.settings.status_code_text }}">
          {{ section.settings.status_code_text | escape }}
        </span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.404.name",
  "tag": "section",
  "class": "section-404-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.404.settings.visual_asset_header.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.404.settings.image.label",
      "info": "t:sections.404.settings.image.info"
    },
    {
      "type": "header",
      "content": "t:sections.404.settings.text_strings_header.content"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "t:sections.404.settings.announcement_text.label",
      "default": "We can’t find the page that you’re looking for"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:sections.404.settings.button_text.label",
      "default": "Back to homepage"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.404.settings.button_link.label",
      "info": "t:sections.404.settings.button_link.info"
    },
    {
      "type": "text",
      "id": "subheadline_text",
      "label": "t:sections.404.settings.subheadline_text.label",
      "default": "Page Not Found"
    },
    {
      "type": "text",
      "id": "status_code_text",
      "label": "t:sections.404.settings.status_code_text.label",
      "default": "404"
    },
    {
      "type": "header",
      "content": "t:sections.404.settings.style_header.content"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.404.settings.bg_color.label",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.404.settings.text_color.label",
      "default": "#1c1c1c"
    },
    {
      "type": "color",
      "id": "announcement_color",
      "label": "t:sections.404.settings.announcement_color.label",
      "default": "#242a33"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "t:sections.404.settings.btn_bg_color.label",
      "default": "#1c1c1c"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "t:sections.404.settings.btn_text_color.label",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}