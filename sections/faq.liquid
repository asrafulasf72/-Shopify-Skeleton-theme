<section
  class="faq"
  aria-labelledby="faq-{{ section.id }}-heading"
>
  <div class="faq__inner">
    <header class="faq__header">
      {% if section.settings.heading != blank %}
        <h2 id="faq-{{ section.id }}-heading" class="faq__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% else %}
        <h2 id="faq-{{ section.id }}-heading" class="faq__heading">
          {{ 'sections.faq.default_heading' | t | escape }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="faq__subheading">
          {{ section.settings.subheading | escape }}
        </p>
      {% endif %}
    </header>

    <div class="faq__items">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'question' %}
            <details
              class="faq__item"
              {{ block.shopify_attributes }}
            >
              <summary class="faq__question">
                {{ block.settings.question | escape }}
              </summary>
              {% if block.settings.answer != blank %}
                <div class="faq__answer">
                  {{ block.settings.answer }}
                </div>
              {% endif %}
            </details>
        {% endcase %}
      {% else %}
        <p class="faq__empty">
          {{ 'sections.faq.empty_state' | t | escape }}
        </p>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .faq {
    padding: 3rem 1.5rem;
  }

  .faq__inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .faq__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .faq__heading {
    margin: 0;
    font-size: clamp(1.75rem, 1.3rem + 1.5vw, 2.25rem);
    line-height: 1.1;
  }

  .faq__subheading {
    margin: 0.75rem 0 0 0;
    color: rgba(0, 0, 0, 0.7);
  }

  .faq__items {
    display: grid;
    gap: 1rem;
  }

  .faq__item {
    border-radius: 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background-color: rgba(255, 255, 255, 0.9);
    padding: 0.75rem 1rem;
  }

  .faq__question {
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    position: relative;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::marker {
    content: "";
  }

  .faq__question::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 0;
    font-weight: 400;
  }

  .faq__item[open] .faq__question::after {
    content: "–";
  }

  .faq__answer {
    margin-top: 0.75rem;
  }

  .faq__empty {
    text-align: center;
    color: rgba(0, 0, 0, 0.6);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.faq.name",
  "tag": "section",
  "class": "faq-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.faq.settings.header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.faq.settings.heading.label",
      "default": "Frequently asked questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.faq.settings.subheading.label"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "t:sections.faq.blocks.question.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.faq.blocks.question.settings.question.label",
          "default": "What is your return policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.faq.blocks.question.settings.answer.label"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.faq.presets.default.name",
      "category": "t:sections.faq.presets.default.category",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "What is your return policy?"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How long does shipping take?"
          }
        }
      ]
    }
  ]
}
{% endschema %}