{% liquid
  assign layout = section.settings.layout
%}

<section
  class="feature-list feature-list--{{ layout }}"
  aria-labelledby="feature-list-{{ section.id }}-heading"
>
  <div class="feature-list__inner">
    <header class="feature-list__header">
      {% if section.settings.heading != blank %}
        <h2 id="feature-list-{{ section.id }}-heading" class="feature-list__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% else %}
        <h2 id="feature-list-{{ section.id }}-heading" class="feature-list__heading">
          {{ 'sections.feature_list.default_heading' | t | escape }}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="feature-list__subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </header>

    <div class="feature-list__items feature-list__items--columns-{{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'feature' %}
            <article
              class="feature-list__item"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.icon != blank %}
                <div class="feature-list__icon" aria-hidden="true">
                  {{ block.settings.icon }}
                </div>
              {% endif %}

              {% if block.settings.heading != blank %}
                <h3 class="feature-list__item-heading">{{ block.settings.heading | escape }}</h3>
              {% endif %}

              {% if block.settings.text != blank %}
                <p class="feature-list__item-text">{{ block.settings.text | escape }}</p>
              {% endif %}

              {% if block.settings.link_label != blank and block.settings.link_url != blank %}
                <p class="feature-list__item-link-wrapper">
                  <a class="feature-list__item-link" href="{{ block.settings.link_url }}">
                    {{ block.settings.link_label | escape }}
                  </a>
                </p>
              {% endif %}
            </article>
        {% endcase %}
      {% else %}
        <p class="feature-list__empty">{{ 'sections.feature_list.empty_state' | t | escape }}</p>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .feature-list {
    padding: 3rem 1.5rem;
  }

  .feature-list__inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .feature-list__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .feature-list__heading {
    margin: 0;
    font-size: clamp(1.75rem, 1.3rem + 1.5vw, 2.25rem);
    line-height: 1.1;
  }

  .feature-list__subheading {
    margin: 0.75rem 0 0 0;
    color: rgba(0, 0, 0, 0.7);
  }

  .feature-list__items {
    display: grid;
    gap: 1.5rem;
  }

  .feature-list__items--columns-1 {
    grid-template-columns: minmax(0, 1fr);
  }

  .feature-list__items--columns-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .feature-list__items--columns-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 767px) {
    .feature-list__items {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .feature-list__item {
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background-color: rgba(255, 255, 255, 0.9);
  }

  .feature-list__icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .feature-list__item-heading {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
  }

  .feature-list__item-text {
    margin: 0;
    color: rgba(0, 0, 0, 0.8);
  }

  .feature-list__item-link-wrapper {
    margin-top: 0.75rem;
  }

  .feature-list__item-link {
    font-size: 0.95rem;
    text-decoration: underline;
    text-underline-offset: 0.1em;
  }

  .feature-list__empty {
    text-align: center;
    color: rgba(0, 0, 0, 0.6);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature list",
  "tag": "section",
  "class": "feature-list-section",
  "settings": [
    {
      "type": "header",
      "content": "Feature list"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Feature list"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "stacked",
      "options": [
        {
          "value": "stacked",
          "label": "Stacked"
        },
        {
          "value": "card",
          "label": "Card"
        }
      ]
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "default": "3",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "info": "Optional icon or emoji displayed above the heading."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Feature list",
      "category": "Text",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "heading": "Free shipping",
            "text": "On all orders over $50."
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Sustainable materials",
            "text": "We prioritize recycled and organic fabrics."
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Easy returns",
            "text": "30-day return policy for peace of mind."
          }
        }
      ]
    }
  ]
}
{% endschema %}