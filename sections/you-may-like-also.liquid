{% liquid
  # Padding: use one desktop value and scale it for laptop, tablet, and mobile
  assign padding_top = section.settings.padding_top | default: 0
  assign laptop_padding_top = padding_top | times: 80 | divided_by: 100
  assign tab_padding_top = laptop_padding_top | times: 80 | divided_by: 100
  assign mobile_padding_top = tab_padding_top | times: 50 | divided_by: 100

  assign padding_bottom = section.settings.padding_bottom | default: 0
  assign laptop_padding_bottom = padding_bottom | times: 80 | divided_by: 100
  assign tab_padding_bottom = laptop_padding_bottom | times: 80 | divided_by: 100
  assign mobile_padding_bottom = tab_padding_bottom | times: 50 | divided_by: 100

  # margin: use one desktop value and scale it for laptop, tablet, and mobile
  assign margin_top = section.settings.margin_top | default: 0
  assign laptop_margin_top = margin_top | times: 80 | divided_by: 100
  assign tab_margin_top = laptop_margin_top | times: 80 | divided_by: 100
  assign mobile_margin_top = tab_margin_top | times: 50 | divided_by: 100

  assign margin_bottom = section.settings.margin_bottom | default: 0
  assign laptop_margin_bottom = margin_bottom | times: 80 | divided_by: 100
  assign tab_margin_bottom = laptop_margin_bottom | times: 80 | divided_by: 100
  assign mobile_margin_bottom = tab_margin_bottom | times: 50 | divided_by: 100

  # Grid: columns from settings
  assign desktop_grid_row = section.settings.desktop_grid_row
  assign laptop_grid_row = section.settings.laptop_grid_row
  assign tab_grid_row = section.settings.tab_grid_row
  assign product_limit = section.settings.product_limit | default: 4
%}

{%- if product -%}
  <div
    class="shopify-section-{{ section.id }} color-{{ section.settings.color_schemes }} nv-product-list nv-recommendations"
    data-section-type="recommendations"
    role="region"
    aria-label="{{ section.settings.heading | escape }}"
    {% unless recommendations.performed and recommendations.products_count > 0 %}
      data-empty="true"
    {% endunless %}
  >
    {% comment %} {% render 'heading', title: section.settings.heading %} {% endcomment %}

    <div class="container">
      <div
        class="nv-product-list__products"
        id="recommendations-{{ section.id }}"
        data-section-id="{{ section.id }}"
        data-product-id="{{ product.id }}"
        data-limit="{{ product_limit }}"
        data-url="{{ routes.product_recommendations_url }}"
        data-desktop-cols="{{ desktop_grid_row }}"
        data-laptop-cols="{{ laptop_grid_row }}"
        data-tab-cols="{{ tab_grid_row }}"
        data-mobile-cols="1"
        aria-live="polite"
        aria-busy="true"
      >
        {%- if recommendations.performed and recommendations.products_count > 0 -%}
          {%- for product in recommendations.products limit: product_limit -%}
            <div class="nv-product-list__item" data-item-index="{{ forloop.index0 }}">
              {% render 'product-card', product: product %}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <!-- Custom scrollbar -->
      <div class="nv-custom-scrollbar" id="scrollbar-{{ section.id }}" aria-hidden="true">
        <div class="nv-custom-scrollbar__thumb" id="scrollbar-thumb-{{ section.id }}"></div>
      </div>
    </div>
  </div>
{%- endif -%}
{% style %}
  /* Mobile: base spacing */
  .shopify-section-{{ section.id }} {
    padding-top: {{ mobile_padding_top }}px;
    padding-bottom: {{ mobile_padding_bottom }}px;
    margin-top: {{ mobile_margin_top }}px;
    margin-bottom: {{ mobile_margin_bottom }}px;
  }

  .shopify-section-{{ section.id }}.nv-recommendations[data-empty="true"] {
    display: none;
  }

  .shopify-section-{{ section.id }}
  .container {
    margin-top: 1.25rem;
  }

  /* Mobile horizontal scroll — native scrollbar hidden */
  .shopify-section-{{ section.id }} .nv-product-list__products {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .shopify-section-{{ section.id }}
  .nv-product-list__products::-webkit-scrollbar {
    display: none;
  }

  /* Custom scrollbar track */
  .shopify-section-{{ section.id }} .nv-custom-scrollbar {
    position: relative;
    width: 100%;
    height: 6px;
    background: #d7dde5;
    border-radius: 999px;
    margin-top: 2rem;
  }

  /* Custom scrollbar thumb */
  .shopify-section-{{ section.id }} .nv-custom-scrollbar__thumb {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: #1c1c1c;
    border-radius: 999px;
    transition: left 0.1s ease, width 0.1s ease;
  }

  /* Product item */
  .shopify-section-{{ section.id }} .nv-product-list__item {
    flex: 0 0 auto;
    width: min(100%, 770px);
    scroll-snap-align: center;
    scroll-snap-stop: always;
    margin: auto;
  }

  /* Hidden items (for responsive column logic) */
  .shopify-section-{{ section.id }} .nv-product-list__item--hidden {
    display: none;
  }

  @media (min-width: 768px) {
    .shopify-section-{{ section.id }} {
      padding-top: {{ tab_padding_top }}px;
      padding-bottom: {{ tab_padding_bottom }}px;
      margin-top: {{ tab_margin_top }}px;
      margin-bottom: {{ tab_margin_bottom }}px;
    }

    .shopify-section-{{ section.id }}
    .container {
      margin-top: 2rem;
    }

    .shopify-section-{{ section.id }} .nv-custom-scrollbar {
      display: none;
    }

    .shopify-section-{{ section.id }}
    .nv-product-list__products {
      display: grid;
      grid-template-columns: repeat({{ tab_grid_row }}, minmax(0, 1fr));
      gap: {{ section.settings.grid_gap }}px;
    }
  }

  @media (min-width: 992px) {
    .shopify-section-{{ section.id }} {
      padding-top: {{ laptop_padding_top }}px;
      padding-bottom: {{ laptop_padding_bottom }}px;
      margin-top: {{ laptop_margin_top }}px;
      margin-bottom: {{ laptop_margin_bottom }}px;
    }

    .shopify-section-{{ section.id }}
    .nv-product-list__products {
      grid-template-columns: repeat({{ laptop_grid_row }}, minmax(0, 1fr));
    }
  }

  @media (min-width: 1400px) {
    .shopify-section-{{ section.id }} {
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
    }

    .shopify-section-{{ section.id }}
    .nv-product-list__products {
      grid-template-columns: repeat({{ desktop_grid_row }}, minmax(0, 1fr));
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "t:sections.you_may_also_like.name",
  "tag": "section",
  "class": "nv-you-may-also-like",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_schemes",
      "label": "t:sections.you_may_also_like.settings.color_schemes.label",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.you_may_also_like.settings.heading.label",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "t:sections.you_may_also_like.settings.product_limit.label",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.you_may_also_like.settings.layout_header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.you_may_also_like.settings.padding_top.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.you_may_also_like.settings.padding_bottom.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "t:sections.you_may_also_like.settings.margin_top.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "t:sections.you_may_also_like.settings.margin_bottom.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "desktop_grid_row",
      "label": "t:sections.you_may_also_like.settings.desktop_grid_row.label",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "laptop_grid_row",
      "label": "t:sections.you_may_also_like.settings.laptop_grid_row.label",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "tab_grid_row",
      "label": "t:sections.you_may_also_like.settings.tab_grid_row.label",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "t:sections.you_may_also_like.settings.grid_gap.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "t:sections.you_may_also_like.presets.default.name"
    }
  ]
}
{% endschema %}
