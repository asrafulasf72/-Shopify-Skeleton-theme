{{ 'footer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign show_newsletter = section.settings.show_newsletter
  assign newsletter_heading = section.settings.newsletter_heading
  assign brand_tagline = section.settings.brand_tagline
  assign show_payment = section.settings.show_payment_icons
  assign show_country = section.settings.show_country_selector

  # margin: use one desktop value and scale it for laptop, tablet, and mobile
  assign margin_top = section.settings.margin_top | default: 0
  assign laptop_margin_top = margin_top | times: 80 | divided_by: 100
  assign tab_margin_top = laptop_margin_top | times: 80 | divided_by: 100
  assign mobile_margin_top = tab_margin_top | times: 50 | divided_by: 100

  assign margin_bottom = section.settings.margin_bottom | default: 0
  assign laptop_margin_bottom = margin_bottom | times: 80 | divided_by: 100
  assign tab_margin_bottom = laptop_margin_bottom | times: 80 | divided_by: 100
  assign mobile_margin_bottom = tab_margin_bottom | times: 50 | divided_by: 100
-%}
<div class="color-{{ section.settings.color_scheme }} shopify-section-{{ section.id }}">
  <div
    class="nv-footer nv-container"
    id="nv-footer"
    role="contentinfo"
    aria-label="{{ shop.name | escape }} footer"
  >
    {%- comment -%}  NEWSLETTER STRIP  {%- endcomment -%}
    {%- if show_newsletter -%}
      {%- render 'footer-newsletter', heading: newsletter_heading -%}
    {%- endif -%}

    {%- comment -%}  MAIN BODY  {%- endcomment -%}
    <div class="nv-footer-body">
      <div class="nv-footer-body-row">
        {%- comment -%} Brand column — always first {%- endcomment -%}
        <div class="nv-footer-brand">
          <a
            href="{{ routes.root_url }}"
            class="nv-footer-logo"
            aria-label="{{ shop.name | escape }} – {{ 'general.accessibility.home' | t | default: 'Go to homepage' }}"
          >
            {%- if section.settings.footer_logo != blank -%}
              {{
                section.settings.footer_logo
                | image_url: width: 200
                | image_tag: loading: 'lazy', width: 120, alt: shop.name
              }}
            {%- else -%}
              <span class="nv-footer-logo-text">{{ shop.name }}</span>
            {%- endif -%}
          </a>

          {%- if brand_tagline != blank -%}
            <div class="nv-footer-tagline-wrapper">
              {%- comment -%}  vertical SVG {%- endcomment -%}
              <span class="nv-footer-tagline-line nv-line-vertical" aria-hidden="true">
                <svg width="6" height="45" viewBox="0 0 6 45" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2.38672 40L-3.26633e-05 45H5.77347L3.38672 40H2.38672ZM2.88672 0L2.38672 0V40.5H2.88672H3.38672V0L2.88672 0Z" fill="currentColor"/>
                </svg>
              </span>

              {%- comment -%}  horizontal SVG {%- endcomment -%}
              <span class="nv-footer-tagline-line nv-line-horizontal" aria-hidden="true">
                <svg
                  width="100%"
                  height="6"
                  viewBox="0 0 295 6"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  preserveAspectRatio="none"
                >
                  <path d="M290 3.38672L295 5.77347V-3.26633e-05L290 2.38672V3.38672ZM0 2.88672L0 3.38672L290.5 3.38672V2.88672V2.38672L0 2.38672L0 2.88672Z" fill="currentColor"/>
                </svg>
              </span>

              <p class="nv-footer-tagline">{{ brand_tagline }}</p>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Dynamic blocks column {%- endcomment -%}
        <div class="nv-footer-blocks-col">
          <div class="nv-footer-blocks-row">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'menu' -%}
                  {%- render 'footer-nav-column', block: block -%}

                {%- when 'social' -%}
                  <div
                    class="nv-footer-block nv-footer-block-social"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.heading != blank -%}
                      <p class="nv-footer-block-heading" id="footer-social-{{ block.id }}">
                        {{ block.settings.heading }}
                      </p>
                    {%- endif -%}

                    <ul
                      class="nv-footer-social-list"
                      role="list"
                      {%- if block.settings.heading != blank -%}
                        aria-labelledby="footer-social-{{ block.id }}"
                      {%- else -%}
                        aria-label="Follow us"
                      {%- endif -%}
                    >
                      {%- if settings.social_facebook_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_facebook_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Facebook"
                            >Facebook</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_instagram_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_instagram_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Instagram"
                            >Instagram</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_twitter_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_twitter_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Twitter / X"
                            >Twitter (X)</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_youtube_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_youtube_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="YouTube"
                            >Youtube</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_tiktok_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_tiktok_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="TikTok"
                            >TikTok</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_linkedin_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_linkedin_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="LinkedIn"
                            >LinkedIn</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_pinterest_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_pinterest_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Pinterest"
                            >Pinterest</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_whatsapp_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_whatsapp_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="WhatsApp"
                            >WhatsApp</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if settings.social_telegram_url != blank -%}
                        <li>
                          <a
                            href="{{ settings.social_telegram_url }}"
                            class="nv-footer-social-link nv-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Telegram"
                            >Telegram</a
                          >
                        </li>
                      {%- endif -%}
                    </ul>
                  </div>

                {%- when 'text' -%}
                  <div
                    class="nv-col-12 nv-col-md-6 nv-col-lg nv-footer-block nv-footer-block-text"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.heading != blank -%}
                      <p class="nv-footer-block-heading">{{ block.settings.heading }}</p>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="nv-footer-block-text rte">{{ block.settings.text }}</div>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>

    {%- comment -%}  BOTTOM BAR {%- endcomment -%}
    {%- render 'footer-bottom-bar',
      show_payment: show_payment,
      show_country: show_country,
      copyright_text: section.settings.copyright_text
    -%}
  </div>
</div>

{% if section.settings.show_bottom_image %}
  <div class="nv-footer-bottom-image-wrapper">
    {% if section.settings.bottom_image != blank %}
      {{
        section.settings.bottom_image
        | image_url: width: 1920
        | image_tag: loading: 'lazy', class: 'nv-footer-bottom-image'
      }}
    {% else %}
      {{ 'image' | placeholder_svg_tag: 'nv-footer-bottom-image placeholder-svg' }}
    {% endif %}
  </div>
{% endif %}

{% style %}
    .shopify-section-{{ section.id }} {
    margin-top: {{ mobile_margin_top }}px;
    margin-bottom: {{ mobile_margin_bottom }}px;
  }

   @media (min-width: 768px) {
     /* Tablet: use tablet padding and column setting */
    .shopify-section-{{ section.id }} {
      margin-top: {{ tab_margin_top }}px;
      margin-bottom: {{ tab_margin_bottom }}px;
    }
   }
      @media (min-width: 992px) {

        /* Laptop: laptop padding and columns */
    .shopify-section-{{ section.id }} {
      margin-top: {{ laptop_margin_top }}px;
      margin-bottom: {{ laptop_margin_bottom }}px;
    }
   }

        @media (min-width: 1280px) {
          .shopify-section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
    }
   }
{% endstyle %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "tag": "footer",
  "class": "nv-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.footer.settings.general_header.content",
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.footer.settings.color_scheme.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "t:sections.footer.settings.margin_top.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "t:sections.footer.settings.margin_bottom.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.newsletter_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.footer.settings.show_newsletter_label.label",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:sections.footer.settings.newsletter_heading.label",
      "default": "t:sections.footer.settings.newsletter_heading.default",
      "visible_if": "{{ section.settings.show_newsletter == true }}"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "t:sections.footer.settings.footer_logo.label",
      "info": "t:sections.footer.settings.footer_logo.info"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "t:sections.footer.settings.brand_tagline.label",
      "default": "t:sections.footer.settings.brand_tagline.default"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.bottom_bar_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "t:sections.footer.settings.show_country_selector_label.label",
      "default": true
    },
    {
      "type": "richtext",
      "id": "copyright_text",
      "label": "t:sections.footer.settings.copyright_text.label",
      "default": "t:sections.footer.settings.copyright_text.default",
    },
        {
      "type": "checkbox",
      "id": "show_bottom_image",
      "label": "t:sections.footer.settings.show_bottom_image.label",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "bottom_image",
      "label": "t:sections.footer.settings.bottom_image_label.label",
      "visible_if": "{{ section.settings.show_bottom_image == true }}",
      "info":"t:sections.footer.settings.bottom_image_label.info"
    }
  ],
  "blocks": [
    
    {
      "type": "menu",
      "name": "t:sections.footer.blocks.menu.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.menu.settings.heading_label",
          "default": "t:sections.footer.blocks.menu.settings.heading_default"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.menu.settings.menu_label"
        }
      ]
    },
    {
      "type": "social",
      "name": "t:sections.footer.blocks.social.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.social.settings.heading_label",
          "default": "t:sections.footer.blocks.social.settings.heading_default"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.text.settings.heading_label"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.footer.blocks.text.settings.text_label"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.footer.presets.default.name",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "heading": "t:sections.footer.presets.default.blocks.menu_discover_heading",
            "menu": "main-menu"
          }
        },
        {
          "type": "menu",
          "settings": {
            "heading": "t:sections.footer.presets.default.blocks.menu_information_heading",
            "menu": "footer"
          }
        },
        {
          "type": "social",
          "settings": {
            "heading": "t:sections.footer.presets.default.blocks.social_heading"
          }
        }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
