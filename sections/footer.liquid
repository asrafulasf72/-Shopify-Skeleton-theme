{{ 'footer.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign show_newsletter = section.settings.show_newsletter
  assign newsletter_heading = section.settings.newsletter_heading
  assign newsletter_subtext = section.settings.newsletter_subtext
  assign brand_tagline = section.settings.brand_tagline
  assign show_payment = section.settings.show_payment_icons
  assign show_country = section.settings.show_country_selector
-%}

<div
  class="sop-footer sop-container color-{{ section.settings.color_scheme }}"
  id="sop-footer"
  role="contentinfo"
  aria-label="{{ shop.name | escape }} footer"
>
  {%- comment -%}  NEWSLETTER STRIP  {%- endcomment -%}
  {%- if show_newsletter -%}
    {%- render 'footer-newsletter', heading: newsletter_heading, subtext: newsletter_subtext -%}
  {%- endif -%}

  {%- comment -%}  MAIN BODY  {%- endcomment -%}
  <div class="sop-footer-body">
    <div class="">
      <div class="sop-footer-body-row">
        {%- comment -%} Brand column — always first {%- endcomment -%}
        <div class="sop-footer-brand">
          <a
            href="{{ routes.root_url }}"
            class="sop-footer-logo"
            aria-label="{{ shop.name | escape }} – {{ 'general.accessibility.home' | t | default: 'Go to homepage' }}"
          >
            {%- if section.settings.footer_logo != blank -%}
              {{
                section.settings.footer_logo
                | image_url: width: 200
                | image_tag: loading: 'lazy', width: 120, alt: shop.name
              }}
            {%- else -%}
              <span class="sop-footer-logo-text">{{ shop.name }}</span>
            {%- endif -%}
          </a>

          {%- if brand_tagline != blank -%}
            <div class="sop-footer-tagline-wrapper">
              {%- comment -%}  vertical SVG {%- endcomment -%}
              <span class="sop-footer-tagline-line sop-line-vertical" aria-hidden="true">
                <svg width="6" height="45" viewBox="0 0 6 45" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M2.38672 40L-3.26633e-05 45H5.77347L3.38672 40H2.38672ZM2.88672 0L2.38672 0V40.5H2.88672H3.38672V0L2.88672 0Z" fill="white"/>
                </svg>
              </span>

              {%- comment -%}  horizontal SVG {%- endcomment -%}
              <span class="sop-footer-tagline-line sop-line-horizontal" aria-hidden="true">
                <svg
                  width="100%"
                  height="6"
                  viewBox="0 0 295 6"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  preserveAspectRatio="none"
                >
                  <path d="M290 3.38672L295 5.77347V-3.26633e-05L290 2.38672V3.38672ZM0 2.88672L0 3.38672L290.5 3.38672V2.88672V2.38672L0 2.38672L0 2.88672Z" fill="white"/>
                </svg>
              </span>

              <p class="sop-footer-tagline">{{ brand_tagline }}</p>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Dynamic blocks column {%- endcomment -%}
        <div class="sop-footer-blocks-col">
          <div class="sop-footer-blocks-row">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'menu' -%}
                  {%- render 'footer-nav-column', block: block -%}

                {%- when 'social' -%}
                  <div
                    class="sop-footer-block sop-footer-block-social"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.heading != blank -%}
                      <p
                        class="sop-footer-block-heading"
                        id="footer-social-{{ block.id }}"
                      >
                        {{ block.settings.heading }}
                      </p>
                    {%- endif -%}

                    <ul
                      class="sop-footer-social-list"
                      role="list"
                      {%- if block.settings.heading != blank -%}
                        aria-labelledby="footer-social-{{ block.id }}"
                      {%- else -%}
                        aria-label="{{ 'general.social.follow_on' | t | default: 'Follow us' }}"
                      {%- endif -%}
                    >
                      {%- if block.settings.facebook_url != blank -%}
                        <li>
                          <a
                            href="{{ block.settings.facebook_url }}"
                            class="sop-footer-social-link sop-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Facebook ({{ 'general.accessibility.new_window' | t | default: 'opens in new tab' }})"
                            >Facebook</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if block.settings.instagram_url != blank -%}
                        <li>
                          <a
                            href="{{ block.settings.instagram_url }}"
                            class="sop-footer-social-link sop-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Instagram ({{ 'general.accessibility.new_window' | t | default: 'opens in new tab' }})"
                            >Instagram</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if block.settings.twitter_url != blank -%}
                        <li>
                          <a
                            href="{{ block.settings.twitter_url }}"
                            class="sop-footer-social-link sop-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Twitter / X ({{ 'general.accessibility.new_window' | t | default: 'opens in new tab' }})"
                            >Twitter (X)</a
                          >
                        </li>
                      {%- endif -%}
                      {%- if block.settings.youtube_url != blank -%}
                        <li>
                          <a
                            href="{{ block.settings.youtube_url }}"
                            class="sop-footer-social-link sop-underline-hover"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="YouTube ({{ 'general.accessibility.new_window' | t | default: 'opens in new tab' }})"
                            >Youtube</a
                          >
                        </li>
                      {%- endif -%}
                    </ul>
                  </div>

                {%- when 'text' -%}
                  <div
                    class="sop-col-12 sop-col-md-6 sop-col-lg sop-footer-block sop-footer-block-text"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.heading != blank -%}
                      <p class="sop-footer-block-heading">{{ block.settings.heading }}</p>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="sop-footer-block-text rte">{{ block.settings.text }}</div>
                    {%- endif -%}
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%}  BOTTOM BAR {%- endcomment -%}
  {%- render 'footer-bottom-bar', show_payment: show_payment, show_country: show_country -%}
</div>
 {% if section.settings.show_bottom_image %}
  <div class="sop-footer-bottom-image-wrapper">
    {% if section.settings.bottom_image != blank %}
      {{
        section.settings.bottom_image
        | image_url: width: 1920
        | image_tag: loading: 'lazy', class: 'sop-footer-bottom-image'
      }}
    {% else %}
      {{ 'image' | placeholder_svg_tag: 'sop-footer-bottom-image placeholder-svg' }}
    {% endif %}
  </div>
{% endif %}
{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "sop-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Brand",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo",
      "info": "Leave blank to use shop name as text"
    },
    {
     "type": "checkbox",
     "id": "show_bottom_image",
     "label": "Bottom sticky image",
     "default": true
    },
    {
      "type": "image_picker",
      "id": "bottom_image",
      "label": "Show Bottom Image"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "Brand tagline",
      "default": "Awesome designs for brands that matter!"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter section",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Unlock your full potential with 50% off!"
    },
    {
      "type": "text",
      "id": "newsletter_subtext",
      "label": "Newsletter subtext",
      "default": "Subscribe to get special offers, free giveaways, and updates."
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icon",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "payment_icon_1",
      "label": "Payment Icon 1"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_2",
      "label": "Payment Icon 2"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_3",
      "label": "Payment Icon 3"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_4",
      "label": "Payment Icon 4"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_5",
      "label": "Payment Icon 5"
    },
    {
      "type": "image_picker",
      "id": "payment_icon_6",
      "label": "Payment Icon 6"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show Country Region Selector",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Discover"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "main-menu"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social Link",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "heading",
          "default": "Social"
        },
        {
          "type": "url",
          "id": "facebook_url",
          "label": "Facebook URL"
        },
        {
          "type": "url",
          "id": "instagram_url",
          "label": "Instagram URL"
        },
        {
          "type": "url",
          "id": "twitter_url",
          "label": "Twitter URL"
        },
        {
          "type": "url",
          "id": "youtube_url",
          "label": "you Tube URL"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "heading": "Menu Discover Heading",
            "menu": "main-menu"
          }
        },
        {
          "type": "menu",
          "settings": {
            "heading": "Menu Information Heading",
            "menu": "footer"
          }
        },
        {
          "type": "social",
          "settings": {
            "heading": "Social Heading"
          }
        }
      ]
    }
  ]
}
{% endschema %}
