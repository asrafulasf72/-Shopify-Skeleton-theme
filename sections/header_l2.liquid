{{ 'header.css' | asset_url | stylesheet_tag: preload: true }}

{%- liquid
  assign default_logo = settings.default_logo
  assign inverse_logo = settings.inverse_logo
  assign logo_width = settings.logo_max_width | default: 72
  assign logo_text_custom = section.settings.logo_text_custom
  assign global_name = logo_text_custom | default: settings.logo_text | default: shop.name
  assign enable_sticky = section.settings.enable_sticky
  assign show_search = section.settings.show_search
  assign show_cart = section.settings.show_cart
  assign show_account = section.settings.show_account
  assign menu = section.settings.menu
-%}

<nav
  class="sop-header color-{{ section.settings.color_scheme }}"
  id="sop-header"
  data-sticky="{{ enable_sticky }}"
  aria-label="{{ 'header.navigation.main' | t }}"
  style="overflow: visible;"
 >
  <div class="sop-header-wrapper container">
    {% comment %}  --- LEFT SLOT --- {% endcomment %}
    <div class="sop-header-slot sop-header-slot-left">
      {%- if menu != blank -%}
        <button
          type="button"
          class="sop-icon-btn sop-hamburger-btn"
          aria-label="{{ 'header.navigation.open_menu' | t }}"
          aria-expanded="false"
          aria-controls="sop-mobile-menu"
          data-mobile-toggle
        >
          <span class="sop-hbg" aria-hidden="true">Menu</span>
        </button>
      {%- endif -%}

      <div class="sop-header-logo-wrapper sop-header-logo-desktop">
        {%- render 'header-logo',
          default_logo: default_logo,
          inverse_logo: inverse_logo,
          logo_width: logo_width,
          global_name: global_name
        -%}
      </div>
    </div>

    {% comment %} ---- CENTER SLOT --- {% endcomment %}
    <div class="sop-header-slot sop-header-slot-center">
      <div class="sop-header-logo-wrapper sop-header-logo-mobile">
        {%- render 'header-logo',
          default_logo: default_logo,
          inverse_logo: inverse_logo,
          logo_width: logo_width,
          global_name: global_name
        -%}
      </div>

      {%- if menu != blank -%}
        {%- render 'header-nav', menu: menu, section: section -%}
      {%- endif -%}
    </div>

    {% comment %} -- RIGHT SLOT -- {% endcomment %}
    <div class="sop-header-slot sop-header-slot-right">
      {%- if show_search -%}
        <button
          type="button"
          class="sop-icon-btn sop-search-btn sop-hide-mobile"
          aria-label="{{ 'header.search.label' | t }}"
          data-search-toggle
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M18.7508 18.7508L13.5538 13.5538M13.5538 13.5538C14.9604 12.1472 15.7506 10.2395 15.7506 8.25028C15.7506 6.26108 14.9604 4.35336 13.5538 2.94678C12.1472 1.54021 10.2395 0.75 8.25028 0.75C6.26108 0.75 4.35336 1.54021 2.94678 2.94678C1.54021 4.35336 0.75 6.26108 0.75 8.25028C0.75 10.2395 1.54021 12.1472 2.94678 13.5538C4.35336 14.9604 6.26108 15.7506 8.25028 15.7506C10.2395 15.7506 12.1472 14.9604 13.5538 13.5538Z"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </button>
      {%- endif -%}

      {%- if show_account -%}
        <a
          href="{{ routes.account_url }}"
          class="sop-icon-btn sop-account-btn sop-hide-mobile"
          aria-label="{{ 'header.account.label' | t }}"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
          >
            <circle cx="12" cy="8" r="4" />
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
          </svg>
        </a>
      {%- endif -%}

      {%- if show_cart -%}
        <a
          href="{{ routes.cart_url }}"
          class="sop-icon-btn sop-cart-btn header-actions__cart-icon"
          data-fly-to-cart-destination
          aria-label="{{ 'header.cart.label' | t }}"
        >
          {%- render 'icons', icon: 'cart' -%}
          <span class="sop-cart-count" aria-hidden="true"
            >(<span class="header-actions__cart-count">{{ cart.item_count }}</span>)</span
          >
        </a>
      {%- endif -%}
    </div>
  </div>
</nav>

<div class="sop-header-spacer" id="sop-header-spacer" aria-hidden="true"></div>

{%- if menu != blank -%}
  {% comment %} -- MOBILE MENU -- {% endcomment %}
  <div
    id="sop-mobile-menu"
    class="sop-mobile-menu color-{{ section.settings.color_scheme }}"
    aria-label="{{ 'header.navigation.main' | t }}"
    aria-hidden="true"
    aria-modal="true"
    role="dialog"
    data-mobile-menu
    data-lenis-prevent
  >
    <div class="sop-mobile-menu-header">
      <div class="sop-mobile-menu-header-logo">
        {%- render 'header-logo',
          default_logo: default_logo,
          inverse_logo: inverse_logo,
          logo_width: logo_width,
          global_name: global_name
        -%}
      </div>

      <div class="sop-mobile-menu-header-actions">
        {%- if show_cart -%}
          <a
            href="{{ routes.cart_url }}"
            class="sop-icon-btn sop-cart-btn"
            aria-label="{{ 'header.cart.label' | t }}"
          >
            {%- render 'icons', icon: 'cart' -%}
            <span class="sop-cart-count" aria-hidden="true">({{ cart.item_count }})</span>
          </a>
        {%- endif -%}

        <button
          type="button"
          class="sop-icon-btn"
          aria-label="{{ 'header.navigation.close_menu' | t }}"
          data-mobile-close
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </div>

    <div class="sop-mobile-menu-dim" aria-hidden="true" data-locale-dim></div>

    <div class="sop-mobile-menu-body" data-lenis-prevent>
      {%- if show_search -%}
        <div class="sop-mobile-search-trigger">
          <button
            type="button"
            class="sop-mobile-search-trigger-btn"
            aria-label="Open search"
            data-search-drawer-open
          >
            <svg
              class="sop-mobile-search-trigger-icon"
              width="18"
              height="18"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M18.7508 18.7508L13.5538 13.5538M13.5538 13.5538C14.9604 12.1472 15.7506 10.2395 15.7506 8.25028C15.7506 6.26108 14.9604 4.35336 13.5538 2.94678C12.1472 1.54021 10.2395 0.75 8.25028 0.75C6.26108 0.75 4.35336 1.54021 2.94678 2.94678C1.54021 4.35336 0.75 6.26108 0.75 8.25028C0.75 10.2395 1.54021 12.1472 2.94678 13.5538C4.35336 14.9604 6.26108 15.7506 8.25028 15.7506C10.2395 15.7506 12.1472 14.9604 13.5538 13.5538Z"
                stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"
              />
            </svg>
            <span class="sop-mobile-search-trigger-text">Search here...</span>
          </button>
        </div>
      {%- endif -%}

      <ul class="sop-mobile-menu-list" role="list">
        {%- for link in linklists[menu].links -%}
          <li class="sop-mobile-menu-item">
            {%- if link.links.size > 0 -%}
              <button
                type="button"
                class="sop-mobile-menu-link sop-mobile-menu-link-parent"
                aria-expanded="false"
                aria-controls="sop-mob-l2-{{ forloop.index }}"
                data-submenu-toggle
              >
                {{- link.title -}}
                <svg
                  class="sop-chevron"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  focusable="false"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>

              <ul
                id="sop-mob-l2-{{ forloop.index }}"
                class="sop-mobile-submenu"
                role="list"
                aria-hidden="true"
              >
                {%- for child in link.links -%}
                  <li class="sop-mobile-submenu-item">
                    {%- if child.links.size > 0 -%}
                      <button
                        type="button"
                        class="sop-mobile-submenu-link sop-mobile-submenu-link-parent"
                        aria-expanded="false"
                        aria-controls="sop-mob-l3-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                        data-submenu-toggle
                      >
                        {{- child.title -}}
                        <svg
                          class="sop-chevron"
                          xmlns="http://www.w3.org/2000/svg"
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                          focusable="false"
                        >
                          <polyline points="6 9 12 15 18 9" />
                        </svg>
                      </button>

                      <ul
                        id="sop-mob-l3-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                        class="sop-mobile-submenu sop-mobile-submenu-l3"
                        role="list"
                        aria-hidden="true"
                      >
                        {%- for grandchild in child.links -%}
                          <li>
                            <a
                              href="{{ grandchild.url }}"
                              class="sop-mobile-submenu-link sop-mobile-submenu-link-l3{% if grandchild.active %} is-active{% endif %}"
                              {% if grandchild.active %}
                                aria-current="page"
                              {% endif %}
                            >
                              {{- grandchild.title -}}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- else -%}
                      <a
                        href="{{ child.url }}"
                        class="sop-mobile-submenu-link{% if child.active %} is-active{% endif %}"
                        {% if child.active %}
                          aria-current="page"
                        {% endif %}
                      >
                        {{- child.title -}}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>

            {%- else -%}
              <a
                href="{{ link.url }}"
                class="sop-mobile-menu-link{% if link.active %} is-active{% endif %}"
                {% if link.active %}
                  aria-current="page"
                {% endif %}
              >
                {{- link.title -}}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
    <div class="sop-mobile-menu-footer">
      <a
        href="{{ routes.account_url }}"
        class="sop-mobile-menu-login-btn"
      >
        {{ 'Login' }}
      </a>

      <button
        type="button"
        class="sop-mobile-menu-locale-trigger"
        aria-expanded="false"
        aria-controls="sop-locale-drawer"
        data-locale-toggle
      >
        <span class="sop-mobile-menu-locale-trigger-text">
          {%- if localization.language != blank -%}
            {{ localization.language.endonym_name }}
          {%- else -%}
            English
          {%- endif -%}
          <span aria-hidden="true"> | </span>
          {%- if localization.country != blank -%}
            {{ localization.country.currency.iso_code }}({{ localization.country.currency.symbol }})
          {%- else -%}
            USD($)
          {%- endif -%}
        </span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          focusable="false"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="sop-locale-drawer"
    class="sop-locale-drawer"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'header.locale.settings_title' | t }}"
    data-locale-view="main"
    data-lenis-prevent
  >
    <div class="sop-locale-view sop-locale-view-main" data-view="main">
      <div class="sop-locale-drawer-header">
        <span class="sop-locale-drawer-title">{{ 'header.locale.settings_title' | t }}</span>
        <button
          type="button"
          class="sop-icon-btn"
          aria-label="{{ 'header.locale.close_settings' | t }}"
          data-locale-close
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <button
        type="button"
        class="sop-locale-drawer-row"
        data-locale-goto="language"
        aria-label="{{ 'header.locale.change_language' | t }}"
      >
        <span class="sop-locale-drawer-row-label">{{ 'header.locale.language' | t }}</span>
        <div class="sop-locale-drawer-row-control">
          <span class="sop-locale-drawer-row-value" data-current-language>
            {{ localization.language.endonym_name }}
          </span>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M8.25 4.5L15.75 12L8.25 19.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </div>
      </button>

      <button
        type="button"
        class="sop-locale-drawer-row"
        data-locale-goto="currency"
        aria-label="{{ 'header.locale.change_currency' | t }}"
      >
        <span class="sop-locale-drawer-row-label">{{ 'header.locale.currency' | t }}</span>
        <div class="sop-locale-drawer-row-control">
          <span class="sop-locale-drawer-row-value" data-current-currency>
            {{ localization.country.currency.iso_code }}({{ localization.country.currency.symbol }})
          </span>
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M8.25 4.5L15.75 12L8.25 19.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </div>
      </button>
    </div>

    <div class="sop-locale-view sop-locale-view-list" data-view="language" aria-hidden="true">
      <div class="sop-locale-drawer-header">
        <button
          type="button"
          class="sop-icon-btn sop-locale-drawer-back"
          aria-label="{{ 'header.locale.back_to_settings' | t }}"
          data-locale-back
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10.5 4.5L3 12L10.5 19.5M3 12H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <span class="sop-locale-drawer-title">{{ 'header.locale.language' | t }}</span>
      </div>

      {%- form 'localization', id: 'sop-language-form', class: 'sop-localization-form' -%}
        <ul
          class="sop-locale-list"
          role="list"
          aria-label="{{ 'header.locale.select_language' | t }}"
          data-lenis-prevent
        >
          {%- for language in localization.available_languages -%}
            <li>
              <button
                type="submit"
                name="language_code"
                value="{{ language.iso_code }}"
                class="sop-locale-list-item{% if language.iso_code == localization.language.iso_code %} sop-locale-list-item-active{% endif %}"
                data-locale-option
                {% if language.iso_code == localization.language.iso_code %}
                  aria-current="true"
                {% endif %}
              >
                {{ language.endonym_name }}
              </button>
            </li>
          {%- endfor -%}
        </ul>
      {%- endform -%}
    </div>

    <div class="sop-locale-view sop-locale-view-list" data-view="currency" aria-hidden="true">
      <div class="sop-locale-drawer-header">
        <button
          type="button"
          class="sop-icon-btn sop-locale-drawer-back"
          aria-label="{{ 'header.locale.back_to_settings' | t }}"
          data-locale-back
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10.5 4.5L3 12L10.5 19.5M3 12H21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <span class="sop-locale-drawer-title">{{ 'header.locale.currency' | t }}</span>
      </div>

      {%- form 'localization', id: 'sop-currency-form', class: 'sop-localization-form' -%}
        <ul
          class="sop-locale-list"
          role="list"
          aria-label="{{ 'header.locale.select_currency' | t }}"
          data-lenis-prevent
        >
          {%- for country in localization.available_countries -%}
            <li>
              <button
                type="submit"
                name="country_code"
                value="{{ country.iso_code }}"
                class="sop-locale-list-item{% if country.iso_code == localization.country.iso_code %} sop-locale-list-item-active{% endif %}"
                data-locale-option
                {% if country.iso_code == localization.country.iso_code %}
                  aria-current="true"
                {% endif %}
              >
                {{ country.currency.iso_code }} ({{ country.currency.symbol }}) — {{ country.name }}
              </button>
            </li>
          {%- endfor -%}
        </ul>
      {%- endform -%}
    </div>
  </div>

  {%- if show_search -%}
    <div
      id="sop-search-drawer"
      class="sop-search-drawer"
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-label="Search"
      data-lenis-prevent
    >
      {%- render 'mobile-inline-search',
        suggested_searches: section.settings.suggested_searches,
        featured_collection: section.settings.featured_collection
      -%}
    </div>
  {%- endif -%}

  <div class="sop-overlay" aria-hidden="true" data-overlay></div>
{%- endif -%}

<script src="{{ 'header.js' | asset_url }}" defer></script>
{% render 'search-modal',
  suggested_searches: section.settings.suggested_searches,
  featured_collection: collections[section.settings.featured_collection]
%}
{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "header",
  "class": "section-header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.header.settings.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.navigation_header.content"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.icons_header.content"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.header.settings.show_search.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "t:sections.header.settings.show_account.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "t:sections.header.settings.show_cart.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.behaviour_header.content"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "t:sections.header.settings.enable_sticky.label",
      "default": true,
      "info": "t:sections.header.settings.enable_sticky.info"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.search_features_header.content"
    },
    {
      "type": "text",
      "id": "suggested_searches",
      "label": "t:sections.header.settings.suggested_searches.label",
      "info": "t:sections.header.settings.suggested_searches.info"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "t:sections.header.settings.featured_collection.label"
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "t:sections.header.blocks.mega_menu.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.header.blocks.mega_menu.settings.nav_link_paragraph.content"
        },
        {
          "type": "text",
          "id": "nav_link_title",
          "label": "t:sections.header.blocks.mega_menu.settings.nav_link_title.label",
          "info": "t:sections.header.blocks.mega_menu.settings.nav_link_title.info"
        },
        {
          "type": "header",
          "content": "t:sections.header.blocks.mega_menu.settings.column_1_header.content"
        },
        {
          "type": "text",
          "id": "col_heading_cats",
          "label": "t:sections.header.blocks.mega_menu.settings.col_heading_cats.label",
          "default": "t:sections.header.blocks.mega_menu.settings.col_heading_cats.default"
        },
        {
          "type": "link_list",
          "id": "categories_menu",
          "label": "t:sections.header.blocks.mega_menu.settings.categories_menu.label",
          "info": "t:sections.header.blocks.mega_menu.settings.categories_menu.info"
        },
        {
          "type": "header",
          "content": "t:sections.header.blocks.mega_menu.settings.column_2_header.content"
        },
        {
          "type": "text",
          "id": "col_heading_brands",
          "label": "t:sections.header.blocks.mega_menu.settings.col_heading_brands.label",
