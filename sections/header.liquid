<header
  class="site-header"
  data-sticky="{{ section.settings.enable_sticky }}"
  aria-label="{{ 'sections.header.aria_label' | t }}"
>
  <div class="site-header__inner">
    <div class="site-header__left">
      {% render 'header-logo', image: section.settings.logo_image, label: section.settings.logo_text | default: shop.name %}
    </div>

    <div class="site-header__center">
      {% if section.settings.menu != blank %}
        {% render 'header-nav', menu: section.settings.menu, section: section %}
        {% render 'mega-menu', blocks: section.blocks %}
      {% endif %}
    </div>
    <div class="site-header__right">
      {% if section.settings.show_search %}
        <a
          href="{{ routes.search_url }}"
          class="site-header__icon-link"
          aria-label="{{ 'sections.header.search_aria_label' | t }}"
        >
          <img src="{{ "search.svg" | asset_url }}" alt="search" height="32" width="32">
        </a>
      {% endif %}

      {% if section.settings.show_account and shop.customer_accounts_enabled %}
        <a
          href="{{ routes.account_url }}"
          class="site-header__icon-link"
          aria-label="{{ 'sections.header.account_aria_label' | t }}"
        >
          <img src="{{ "icon-account.svg" | asset_url }}" alt="account" height="32" width="32">
        </a>
      {% endif %}

      {% if section.settings.show_cart %}
        <button
          type="button"
          class="site-header__icon-link site-header__cart-toggle"
          aria-label="{{ 'sections.header.cart_aria_label' | t }}"
          aria-expanded="false"
          aria-controls="cart-drawer"
        >
          <img src="{{ "cart.svg" | asset_url }}" alt="cart" height="32" width="32">
          <span
            class="site-header__cart-count"
            style="display: {% if cart.item_count > 0 %}inline-flex{% else %}none{% endif %};"
          >
            {{ cart.item_count }}
          </span>
        </button>
      {% endif %}

      {% if section.settings.menu != blank %}
        <button
          class="site-header__mobile-toggle"
          aria-label="{{ 'sections.header.mobile_menu_toggle_aria_label' | t }}"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
        >
          <span class="site-header__hamburger">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      {% endif %}
    </div>
  </div>

  {% if section.settings.menu != blank %}
    <div class="site-header__mobile-panel" id="mobile-menu-panel" aria-hidden="true">
      <nav class="site-header__mobile-nav">
        {% render 'header-nav', menu: section.settings.menu, section: section %}
      </nav>
    </div>
  {% endif %}

  <div
    class="cart-drawer"
    id="cart-drawer"
    aria-hidden="true"
    aria-label="{{ 'sections.header.cart_drawer_aria_label' | t }}"
    role="dialog"
  >
    <div class="cart-drawer__overlay" data-cart-drawer-close></div>
    <div class="cart-drawer__panel" role="document">
      <header class="cart-drawer__header">
        <h2 class="cart-drawer__title">{{ 'sections.header.cart_drawer_title' | t }}</h2>
        <button
          type="button"
          class="cart-drawer__close"
          aria-label="{{ 'sections.header.cart_drawer_close_aria_label' | t }}"
          data-cart-drawer-close
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </header>

      <div class="cart-drawer__body">
       
      </div>

      <footer class="cart-drawer__footer">
        <div class="cart-drawer__subtotal">
          <span>{{ 'sections.header.cart_drawer_subtotal' | t }}</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-drawer__actions">
          <a
            href="{{ routes.cart_url }}"
            class="cart-drawer__button cart-drawer__button--secondary"
          >
            {{ 'sections.header.cart_drawer_view_cart' | t }}
          </a>
          <a
            href="{{ routes.checkout_url }}"
            class="cart-drawer__button cart-drawer__button--primary"
          >
            {{ 'sections.header.cart_drawer_checkout' | t }}
          </a>
        </div>
      </footer>
    </div>
  </div>
</header>

{% comment %}
  {% stylesheet %}

  {% endstylesheet %}
{% endcomment %}

{% javascript %}
  (function () {
    const header = document.querySelector('.site-header');
    if (!header) return;

    const stickyEnabled = header.dataset.sticky === 'true';

    if (stickyEnabled) {
      const placeholder = document.createElement('div');
      placeholder.classList.add('site-header-placeholder');
      header.insertAdjacentElement('afterend', placeholder);

      let isSticky = false;

      function updateSticky() {
        const triggerPoint = header.offsetTop + header.offsetHeight;

        if (window.scrollY > triggerPoint && !isSticky) {
          isSticky = true;
          placeholder.style.height = header.offsetHeight + 'px';
          placeholder.classList.add('site-header-placeholder--active');
          header.classList.add('site-header--sticky');
        } else if (window.scrollY <= triggerPoint && isSticky) {
          isSticky = false;
          placeholder.style.height = '0';
          placeholder.classList.remove('site-header-placeholder--active');
          header.classList.remove('site-header--sticky');
        }
      }

      window.addEventListener('scroll', updateSticky, { passive: true });
    }

    const toggle = header.querySelector('.site-header__mobile-toggle');
    const panel = header.querySelector('.site-header__mobile-panel');

    if (toggle && panel) {
      toggle.addEventListener('click', function () {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        panel.setAttribute('aria-hidden', String(isOpen));
        panel.classList.toggle('is-open', !isOpen);
      });

      document.addEventListener('click', function (event) {
        if (!header.contains(event.target)) {
          toggle.setAttribute('aria-expanded', 'false');
          panel.setAttribute('aria-hidden', 'true');
          panel.classList.remove('is-open');
        }
      });

      window.addEventListener('resize', function () {
        if (window.innerWidth > 768) {
          toggle.setAttribute('aria-expanded', 'false');
          panel.setAttribute('aria-hidden', 'true');
          panel.classList.remove('is-open');
        }
      });
    }

    const cartDrawer = document.getElementById('cart-drawer');
    const cartToggle = header.querySelector('.site-header__cart-toggle');

    if (cartDrawer && cartToggle) {
      const closeElements = cartDrawer.querySelectorAll('[data-cart-drawer-close]');

      function openCartDrawer() {
        cartDrawer.setAttribute('aria-hidden', 'false');
        cartToggle.setAttribute('aria-expanded', 'true');
      }

      function closeCartDrawer() {
        cartDrawer.setAttribute('aria-hidden', 'true');
        cartToggle.setAttribute('aria-expanded', 'false');
      }

      cartToggle.addEventListener('click', function () {
        const isOpen = cartDrawer.getAttribute('aria-hidden') === 'false';

        if (isOpen) {
          closeCartDrawer();
        } else {
          if (document.startViewTransition) {
            document.startViewTransition(function () {
              openCartDrawer();
            });
          } else {
            openCartDrawer();
          }
        }
      });

      closeElements.forEach(function (element) {
        element.addEventListener('click', function () {
          closeCartDrawer();
        });
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          const isOpen = cartDrawer.getAttribute('aria-hidden') === 'false';
          if (isOpen) {
            closeCartDrawer();
          }
        }
      });
    }
  })();

  document.querySelectorAll('.header-nav__item').forEach((item) => {
    item.addEventListener('mouseenter', function () {
      let name = this.dataset.menu;

      document.querySelectorAll('.mega-panel').forEach((panel) => {
        panel.classList.remove('active');

        if (panel.dataset.menu === name) {
          panel.classList.add('active');
        }
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "t:sections.header.settings.logo_image.label"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:sections.header.settings.logo_text.label",
      "default": "My Store"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.header.settings.show_search.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "t:sections.header.settings.show_account.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "t:sections.header.settings.show_cart.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "t:sections.header.settings.enable_sticky.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega Menu",
      "settings": [
        { "type": "text", "id": "link_name", "label": "Menu Link Name" },
        { "type": "link_list", "id": "link_list_1", "label": "Link Column 1" },
        { "type": "link_list", "id": "link_list_2", "label": "Link Column 2" },
        { "type": "link_list", "id": "link_list_3", "label": "Link Column 3" },
        { "type": "image_picker", "id": "first_image", "label": "Image Card 1" },
        { "type": "url", "id": "first_image_url", "label": "Image 1 URL" },
        { "type": "text", "id": "highlight_overlay_text", "label": "Image 1 Bold Text", "default": "Weekly" },
        { "type": "text", "id": "overlay_text", "label": "Image 1 Sub Text", "default": "Top sales" },
        { "type": "image_picker", "id": "second_image", "label": "Image Card 2" },
        { "type": "url", "id": "second_image_url", "label": "Image 2 URL" },
        { "type": "text", "id": "highlight_overlay_text_second", "label": "Image 2 Bold Text", "default": "50% Off" },
        { "type": "text", "id": "overlay_text_second", "label": "Image 2 Sub Text", "default": "On this order" }
      ]
    },
    {
      "type": "nav_badge",
      "name": "Nav Badge",
      "settings": [
        {
          "type": "text",
          "id": "link_name",
          "label": "Menu Link Name",
          "info": "Must match the exact menu link title (case-sensitive)"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "default": "New"
        },
        {
          "type": "range",
          "id": "badge_padding_x",
          "label": "Badge Horizontal Padding",
          "min": 4,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": 8
        },
        {
          "type": "range",
          "id": "badge_padding_y",
          "label": "Badge Vertical Padding",
          "min": 2,
          "max": 12,
          "step": 1,
          "unit": "px",
          "default": 4
        },
        {
          "type": "color",
          "id": "badge_bg_color",
          "label": "Badge Background Color",
          "default": "#ef4444"
        },
        {
          "type": "color",
          "id": "badge_text_color",
          "label": "Badge Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.header.presets.default.name"
    }
  ]
}
{% endschema %}
