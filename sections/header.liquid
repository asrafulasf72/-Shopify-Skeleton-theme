<header
  class="site-header"
  data-sticky="{{ section.settings.enable_sticky }}"
  aria-label="{{ 'sections.header.aria_label' | t }}"
>
  <div class="site-header__inner">
    <div class="site-header__left">
      {% render 'header-logo', image: section.settings.logo_image, label: section.settings.logo_text | default: shop.name %}
    </div>

    <div class="site-header__center">
      {% if section.settings.menu != blank %}
        {% render 'header-nav', menu: section.settings.menu, section: section %}
        {% render 'mega-menu', blocks: section.blocks %}
      {% endif %}
    </div>
    <div class="site-header__right">
      {% if section.settings.show_search %}
        <a
          href="{{ routes.search_url }}"
          class="site-header__icon-link"
          aria-label="{{ 'sections.header.search_aria_label' | t }}"
        >
          <img src="{{ "search.svg" | asset_url }}" alt="search" height="32" width="32">
        </a>
      {% endif %}

      {% if section.settings.show_account and shop.customer_accounts_enabled %}
        <a
          href="{{ routes.account_url }}"
          class="site-header__icon-link"
          aria-label="{{ 'sections.header.account_aria_label' | t }}"
        >
          <img src="{{ "icon-account.svg" | asset_url }}" alt="account" height="32" width="32">
        </a>
      {% endif %}

      {% if section.settings.show_cart %}
        <button
          type="button"
          class="site-header__icon-link site-header__cart-toggle"
          aria-label="{{ 'sections.header.cart_aria_label' | t }}"
          aria-expanded="false"
          aria-controls="cart-drawer"
        >
          <img src="{{ "cart.svg" | asset_url }}" alt="cart" height="32" width="32">
          {% if cart != empty and cart.item_count > 0 %}
            <span class="site-header__cart-count">{{ cart.item_count }}</span>
          {% endif %}
        </button>
      {% endif %}

      {% if section.settings.menu != blank %}
        <button
          class="site-header__mobile-toggle"
          aria-label="{{ 'sections.header.mobile_menu_toggle_aria_label' | t }}"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
        >
          <span class="site-header__hamburger">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>
      {% endif %}
    </div>
  </div>

  {% if section.settings.menu != blank %}
    <div class="site-header__mobile-panel" id="mobile-menu-panel" aria-hidden="true">
      <nav class="site-header__mobile-nav">
        {% render 'header-nav', menu: section.settings.menu, section: section %}
      </nav>
    </div>
  {% endif %}

  <div
    class="cart-drawer"
    id="cart-drawer"
    aria-hidden="true"
    aria-label="{{ 'sections.header.cart_drawer_aria_label' | t }}"
    role="dialog"
  >
    <div class="cart-drawer__overlay" data-cart-drawer-close></div>
    <div class="cart-drawer__panel" role="document">
      <header class="cart-drawer__header">
        <h2 class="cart-drawer__title">{{ 'sections.header.cart_drawer_title' | t }}</h2>
        <button
          type="button"
          class="cart-drawer__close"
          aria-label="{{ 'sections.header.cart_drawer_close_aria_label' | t }}"
          data-cart-drawer-close
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </header>

      <div class="cart-drawer__body">
        {% if cart != empty and cart.item_count > 0 %}
          <ul class="cart-drawer__items" role="list">
            {% for item in cart.items %}
              <li class="cart-drawer__item">
                <div class="cart-drawer__item-image">
                  {% if item.image %}
                    {{
                      item.image
                      | image_url: width: 120, height: 120
                      | image_tag: loading: 'lazy', alt: item.product.title
                      | escape
                    }}
                  {% endif %}
                </div>
                <div class="cart-drawer__item-content">
                  <a href="{{ item.url }}" class="cart-drawer__item-title">
                    {{ item.product.title | escape }}
                  </a>

                  {% if item.variant.title and item.variant.title != 'Default Title' %}
                    <p class="cart-drawer__item-variant">
                      {{ item.variant.title | escape }}
                    </p>
                  {% endif %}

                  <p class="cart-drawer__item-quantity">
                    {{ 'sections.header.cart_drawer_quantity' | t: quantity: item.quantity }}
                  </p>

                  <p class="cart-drawer__item-price">
                    {{ item.final_line_price | money }}
                  </p>
                </div>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <p class="cart-drawer__empty">
            {{ 'sections.header.cart_drawer_empty' | t }}
          </p>
        {% endif %}
      </div>

      <footer class="cart-drawer__footer">
        <div class="cart-drawer__subtotal">
          <span>{{ 'sections.header.cart_drawer_subtotal' | t }}</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <div class="cart-drawer__actions">
          <a
            href="{{ routes.cart_url }}"
            class="cart-drawer__button cart-drawer__button--secondary"
          >
            {{ 'sections.header.cart_drawer_view_cart' | t }}
          </a>
          <a
            href="{{ routes.checkout_url }}"
            class="cart-drawer__button cart-drawer__button--primary"
          >
            {{ 'sections.header.cart_drawer_checkout' | t }}
          </a>
        </div>
      </footer>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    background-color: #ffffff;
    color: #111827;
    position: relative;
    z-index: 100;
    width: 100%;
    transition: box-shadow 0.3s ease;
  }

  .site-header--sticky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 100;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
    animation: headerSlideDown 0.3s ease forwards;
  }

  @keyframes headerSlideDown {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .site-header-placeholder {
    display: none;
  }

  .site-header-placeholder--active {
    display: block;
  }

  .site-header__inner {
    max-width: 80rem;
    margin-inline: auto;
    padding: 0.75rem 1.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .site-header__left {
    justify-self: flex-start;
  }

  .site-header__center {
    justify-self: center;
  }

  .site-header__right {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .site-header__icon-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .site-header__icon-link:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .site-header__icon-link:focus-visible {
    outline: 2px solid #111827;
    outline-offset: 2px;
  }

  .site-header__icon {
    font-size: 1rem;
  }

  .site-header__cart-count {
    position: absolute;
    top: -0.25rem;
    right: -0.25rem;
    min-width: 1.1rem;
    height: 1.1rem;
    padding: 0 0.2rem;
    border-radius: 999px;
    background-color: #111827;
    color: #ffffff;
    font-size: 0.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .site-header__mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 2rem;
    height: 2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    border-radius: 999px;
    transition: background 0.2s;
  }

  .site-header__mobile-toggle:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .site-header__hamburger {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }

  .site-header__hamburger span {
    display: block;
    height: 2px;
    width: 100%;
    background-color: #111827;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    transform-origin: center;
  }

  .site-header__mobile-toggle[aria-expanded='true'] .site-header__hamburger span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .site-header__mobile-toggle[aria-expanded='true'] .site-header__hamburger span:nth-child(2) {
    opacity: 0;
    width: 0;
  }

  .site-header__mobile-toggle[aria-expanded='true'] .site-header__hamburger span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .site-header__mobile-panel {
    display: none;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease;
    opacity: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    background: #ffffff;
  }

  .site-header__mobile-panel.is-open {
    max-height: 500px;
    opacity: 1;
  }

  .site-header__mobile-nav {
    max-width: 80rem;
    margin-inline: auto;
    padding: 1rem 1.5rem 1.25rem;
  }

  .site-header__mobile-nav .header-nav__list {
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 0 !important;
  }

  .site-header__mobile-nav .header-nav__item a {
    display: block;
    padding: 0.65rem 0;
    font-size: 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    color: #111827;
    text-decoration: none;
    transition: color 0.2s;
  }

  .site-header__mobile-nav .header-nav__item:last-child a {
    border-bottom: none;
  }

  .site-header__mobile-nav .header-nav__item a:hover {
    color: #6366f1;
  }

  /* CART DRAWER – LEFT SIDE, FULL HEIGHT */
  .cart-drawer {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 200;
    display: flex;
    justify-content: flex-start;
    pointer-events: none;
  }

  .cart-drawer[aria-hidden='true'] {
    visibility: hidden;
  }

  .cart-drawer[aria-hidden='false'] {
    pointer-events: auto;
    visibility: visible;
  }

  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(15, 23, 42, 0.4);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .cart-drawer[aria-hidden='false'] .cart-drawer__overlay {
    opacity: 1;
  }

  .cart-drawer__panel {
    position: relative;
    margin-right: auto;
    width: min(420px, 100%);
    max-width: 100%;
    height: 100vh;
    background-color: #ffffff;
    box-shadow: 8px 0 24px rgba(15, 23, 42, 0.15);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }

  .cart-drawer[aria-hidden='false'] .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .cart-drawer__title {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0;
  }

  .cart-drawer__close {
    border: none;
    background: none;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 999px;
    line-height: 1;
  }

  .cart-drawer__close:focus-visible {
    outline: 2px solid #111827;
    outline-offset: 2px;
  }

  .cart-drawer__body {
    flex: 1 1 auto;
    padding: 1rem 1.5rem;
    overflow-y: auto;
  }

  .cart-drawer__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .cart-drawer__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .cart-drawer__item-image img {
    border-radius: 0.5rem;
    width: 72px;
    height: 72px;
    object-fit: cover;
  }

  .cart-drawer__item-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 500;
    color: inherit;
    text-decoration: none;
    margin-bottom: 0.125rem;
  }

  .cart-drawer__item-title:hover {
    text-decoration: underline;
  }

  .cart-drawer__item-variant {
    font-size: 0.8rem;
    color: #6b7280;
    margin: 0 0 0.25rem;
  }

  .cart-drawer__item-quantity,
  .cart-drawer__item-price {
    font-size: 0.85rem;
    margin: 0;
  }

  .cart-drawer__item-price {
    font-weight: 500;
  }

  .cart-drawer__empty {
    margin: 0;
    font-size: 0.95rem;
    color: #6b7280;
  }

  .cart-drawer__footer {
    padding: 1rem 1.5rem 1.25rem;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    display: grid;
    gap: 0.75rem;
  }

  .cart-drawer__subtotal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .cart-drawer__actions {
    display: grid;
    gap: 0.5rem;
  }

  .cart-drawer__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
  }

  .cart-drawer__button--primary {
    background-color: #111827;
    color: #ffffff;
  }

  .cart-drawer__button--primary:hover {
    background-color: #020617;
  }

  .cart-drawer__button--secondary {
    background-color: #ffffff;
    color: #111827;
    border-color: rgba(15, 23, 42, 0.15);
  }

  .cart-drawer__button--secondary:hover {
    background-color: #f9fafb;
  }

  @media (max-width: 768px) {
    .site-header__center {
      display: none;
    }

    .site-header__mobile-toggle {
      display: flex;
    }

    .site-header__mobile-panel {
      display: block;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const header = document.querySelector('.site-header');
    if (!header) return;

    const stickyEnabled = header.dataset.sticky === 'true';

    if (stickyEnabled) {
      const placeholder = document.createElement('div');
      placeholder.classList.add('site-header-placeholder');
      header.insertAdjacentElement('afterend', placeholder);

      let isSticky = false;

      function updateSticky() {
        const triggerPoint = header.offsetTop + header.offsetHeight;

        if (window.scrollY > triggerPoint && !isSticky) {
          isSticky = true;
          placeholder.style.height = header.offsetHeight + 'px';
          placeholder.classList.add('site-header-placeholder--active');
          header.classList.add('site-header--sticky');
        } else if (window.scrollY <= triggerPoint && isSticky) {
          isSticky = false;
          placeholder.style.height = '0';
          placeholder.classList.remove('site-header-placeholder--active');
          header.classList.remove('site-header--sticky');
        }
      }

      window.addEventListener('scroll', updateSticky, { passive: true });
    }

    const toggle = header.querySelector('.site-header__mobile-toggle');
    const panel = header.querySelector('.site-header__mobile-panel');

    if (toggle && panel) {
      toggle.addEventListener('click', function () {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        panel.setAttribute('aria-hidden', String(isOpen));
        panel.classList.toggle('is-open', !isOpen);
      });

      document.addEventListener('click', function (event) {
        if (!header.contains(event.target)) {
          toggle.setAttribute('aria-expanded', 'false');
          panel.setAttribute('aria-hidden', 'true');
          panel.classList.remove('is-open');
        }
      });

      window.addEventListener('resize', function () {
        if (window.innerWidth > 768) {
          toggle.setAttribute('aria-expanded', 'false');
          panel.setAttribute('aria-hidden', 'true');
          panel.classList.remove('is-open');
        }
      });
    }

    const cartDrawer = document.getElementById('cart-drawer');
    const cartToggle = header.querySelector('.site-header__cart-toggle');

    if (cartDrawer && cartToggle) {
      const closeElements = cartDrawer.querySelectorAll('[data-cart-drawer-close]');

      function openCartDrawer() {
        cartDrawer.setAttribute('aria-hidden', 'false');
        cartToggle.setAttribute('aria-expanded', 'true');
      }

      function closeCartDrawer() {
        cartDrawer.setAttribute('aria-hidden', 'true');
        cartToggle.setAttribute('aria-expanded', 'false');
      }

      cartToggle.addEventListener('click', function () {
        const isOpen = cartDrawer.getAttribute('aria-hidden') === 'false';

        if (isOpen) {
          closeCartDrawer();
        } else {
          if (document.startViewTransition) {
            document.startViewTransition(function () {
              openCartDrawer();
            });
          } else {
            openCartDrawer();
          }
        }
      });

      closeElements.forEach(function (element) {
        element.addEventListener('click', function () {
          closeCartDrawer();
        });
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          const isOpen = cartDrawer.getAttribute('aria-hidden') === 'false';
          if (isOpen) {
            closeCartDrawer();
          }
        }
      });
    }
  })();

  document.querySelectorAll('.header-nav__item').forEach((item) => {
    item.addEventListener('mouseenter', function () {
      let name = this.dataset.menu;

      document.querySelectorAll('.mega-panel').forEach((panel) => {
        panel.classList.remove('active');

        if (panel.dataset.menu === name) {
          panel.classList.add('active');
        }
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "t:sections.header.settings.logo_image.label"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "t:sections.header.settings.logo_text.label",
      "default": "My Store"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.header.settings.show_search.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "t:sections.header.settings.show_account.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "t:sections.header.settings.show_cart.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "t:sections.header.settings.enable_sticky.label",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "Mega Menu",
      "settings": [
        { "type": "text", "id": "link_name", "label": "Menu Link Name" },
        { "type": "link_list", "id": "link_list_1", "label": "Link Column 1" },
        { "type": "link_list", "id": "link_list_2", "label": "Link Column 2" },
        { "type": "link_list", "id": "link_list_3", "label": "Link Column 3" },
        { "type": "image_picker", "id": "first_image", "label": "Image Card 1" },
        { "type": "url", "id": "first_image_url", "label": "Image 1 URL" },
        { "type": "text", "id": "highlight_overlay_text", "label": "Image 1 Bold Text", "default": "Weekly" },
        { "type": "text", "id": "overlay_text", "label": "Image 1 Sub Text", "default": "Top sales" },
        { "type": "image_picker", "id": "second_image", "label": "Image Card 2" },
        { "type": "url", "id": "second_image_url", "label": "Image 2 URL" },
        { "type": "text", "id": "highlight_overlay_text_second", "label": "Image 2 Bold Text", "default": "50% Off" },
        { "type": "text", "id": "overlay_text_second", "label": "Image 2 Sub Text", "default": "On this order" }
      ]
    },
    {
      "type": "nav_badge",
      "name": "Nav Badge",
      "settings": [
        {
          "type": "text",
          "id": "link_name",
          "label": "Menu Link Name",
          "info": "Must match the exact menu link title (case-sensitive)"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "default": "New"
        },
        {
          "type": "range",
          "id": "badge_padding_x",
          "label": "Badge Horizontal Padding",
          "min": 4,
          "max": 20,
          "step": 1,
          "unit": "px",
          "default": 8
        },
        {
          "type": "range",
          "id": "badge_padding_y",
          "label": "Badge Vertical Padding",
          "min": 2,
          "max": 12,
          "step": 1,
          "unit": "px",
          "default": 4
        },
        {
          "type": "color",
          "id": "badge_bg_color",
          "label": "Badge Background Color",
          "default": "#ef4444"
        },
        {
          "type": "color",
          "id": "badge_text_color",
          "label": "Badge Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.header.presets.default.name"
    }
  ]
}
{% endschema %}
