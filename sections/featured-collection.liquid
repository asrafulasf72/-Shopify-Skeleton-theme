 {{ 'featured-collection.css' | asset_url | stylesheet_tag: preload: true}}
<section
  class="featured-collection"
  id="featured-collection-{{ section.id }}"
  data-hover-style="{{ section.settings.image_hover_style }}"
  data-media-type="{{ section.settings.card_media_type }}"
>
  <div class="featured-collection__header">
    {% if section.settings.heading != '' %}
      <h2 class="featured-collection__title">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}
    {% if section.settings.subheading != '' %}
      <p class="featured-collection__subtitle">
        {{ section.settings.subheading | escape }}
      </p>
    {% endif %}
  </div>

  {% assign collection = section.settings.collection %}

  {% if collection and collection.products_count > 0 %}
    <div
      class="featured-collection__grid"
      style="
        --columns-desktop: {{ section.settings.columns_desktop }};
        --columns-mobile: {{ section.settings.columns_mobile }};
        --card-gap: {{ section.settings.card_gap }}px;
      "
    >
      {% for product in collection.products limit: section.settings.products_to_show %}
  {% render 'product-card', product: product, section: section %}
{% endfor %}
    </div>
  {% else %}
    <div
      class="featured-collection__grid"
      style="
        --columns-desktop: {{ section.settings.columns_desktop }};
        --columns-mobile: {{ section.settings.columns_mobile }};
        --card-gap: {{ section.settings.card_gap }}px;
      "
    >
      {% for i in (1..4) %}
        <article class="product-card product-card--placeholder">
          <div class="product-card__media">
            <div class="product-card__placeholder">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          </div>
          <div class="product-card__info">
            <h3 class="product-card__title">
              <span>Product title</span>
            </h3>
            <p class="product-card__meta">Available in multiple colours</p>
            <div class="product-card__price">
              <span class="product-card__price--regular"> $0.00 </span>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}

  <!-- ═══════════════════════════════════════
       QUICK VIEW MODAL
  ═══════════════════════════════════════ --> 
  {% render 'quick-view-modal', section: section %}
</section>

{% javascript %}
  // ══════════════════════════════════════════
  // CLICK-MODE: image slider for product cards
  // ══════════════════════════════════════════
  (function () {
    const section = document.querySelector('[data-media-type]');
    if (!section || section.dataset.mediaType !== 'click') return;

    section.querySelectorAll('.product-card').forEach((card) => {
      const track  = card.querySelector('.product-card__click-track');
      if (!track) return;

      const slides = Array.from(track.querySelectorAll('.product-card__click-slide'));
      const dots   = Array.from(card.querySelectorAll('.product-card__dot'));
      const total  = slides.length;
      if (total <= 1) return;

      let current = 0;

      function goTo(index) {
        // wrap around
        index = (index + total) % total;

        // update slides
        slides[current].classList.remove('is-active');
        slides[index].classList.add('is-active');

        // update dots
        if (dots[current]) dots[current].classList.remove('is-active');
        if (dots[index])   dots[index].classList.add('is-active');

        current = index;
      }

      // Prev / Next buttons — stop link navigation
      const prevBtn = card.querySelector('[data-nav="prev"]');
      const nextBtn = card.querySelector('[data-nav="next"]');

      if (prevBtn) {
        prevBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          goTo(current - 1);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          goTo(current + 1);
        });
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Space between product cards",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "select",
      "id": "card_media_type",
      "label": "Product image browsing style",
      "info": "Choose how customers browse multiple product images",
      "options": [
        { "value": "hover", "label": "Auto-switch on hover" },
        { "value": "click", "label": "Click arrows to browse" }
      ],
      "default": "hover"
    },
    {
      "type": "select",
      "id": "image_hover_style",
      "label": "Image hover transition effect",
      "info": "Only applies when 'Auto-switch on hover' is selected above",
      "options": [
        { "value": "slide", "label": "Slide" },
        { "value": "fade",  "label": "Fade" },
        { "value": "flip",  "label": "Flip" }
      ],
      "default": "slide",
      "visible_if": "{{ section.settings.card_media_type == 'hover' }}"
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show add to cart button",
      "default": true
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of products to show",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
