<section class="example-hero" aria-labelledby="example-hero-title">
  <div class="example-hero__inner">
    {% render 'example-heading',
  heading: section.settings.heading,
  subheading: section.settings.text
%}

    {% if section.settings.show_button and section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="example-hero__button">
        {{ section.settings.button_label | escape }}
      </a>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .example-hero {
    padding-block: 4rem;
  }

  .example-hero__inner {
    max-width: 60rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
    text-align: center;
  }

  .example-hero__title {
    font-size: clamp(2rem, 1.5rem + 1.5vw, 2.75rem);
    font-weight: 600;
  }

  .example-hero__text {
    margin-top: 0.75rem;
    color: rgba(0, 0, 0, 0.75);
  }

  .example-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    background: #111827;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
  }

  .example-hero__button:focus-visible {
    outline: 2px solid #111827;
    outline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.example_hero.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.example_hero.settings.heading.label",
      "default": "Example hero section"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "t:sections.example_hero.settings.text.label",
      "default": "Use this section to learn how theme sections work."
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "t:sections.example_hero.settings.show_button.label",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.example_hero.settings.button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.example_hero.settings.button_link.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.example_hero.presets.default.name"
    }
  ]
}
{% endschema %}