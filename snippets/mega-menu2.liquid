{%- liquid
  assign marquee_text1 = block.settings.marquee_text_1 | default: 'Check out our latest products!'
  assign marquee_text2 = block.settings.marquee_text_2 | default: "Discover what's new in store!"
  assign featured_products = block.settings.featured_products
  assign hero_image = block.settings.hero_image
  assign categories_list = linklists[block.settings.categories_menu]
  assign brand_list = linklists[block.settings.brands_menu]
-%}

<div class="nv-mega-menu-clip">
  <div
  class="nv-mega-menu"
  id="nv-mega-{{ block.id }}"
  role="dialog"
  aria-label="Mega menu"
  aria-hidden="true"
  data-mega-panel
 >
  <div class="nv-mega-menu-wrapper nv-container">
    <div class="nv-mega-menu-col nv-mega-menu-col-cats">
      <p class="nv-mega-menu-col-heading">{{ block.settings.col_heading_cats | default: 'Categories' | upcase }}</p>

      {%- if categories_list and categories_list.links.size > 0 -%}
        <ul class="nv-mega-menu-cat-list" role="list">
          {%- for link in categories_list.links -%}
            <li>
              <a
                href="{{ link.url }}"
                class="nv-mega-menu-cat-link{% if link.active %} is-active{% endif %}"
              >
                <span class="nv-mega-menu-cat-name nv-underline-hover">{{ link.title | escape }}</span>
                {%- if link.object and link.object.all_products_count -%}
                  <span class="nv-mega-menu-cat-count">
                    {{ link.object.all_products_count }}
                  </span>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p style="font-size: 0.8125rem; color: var(--nv-header-color-muted); padding: 0 0 1rem;">
          No categories menu selected.
        </p>
      {%- endif -%}
    </div>

    <div class="nv-mega-menu-col nv-mega-menu-col-brands">
      <p class="nv-mega-menu-col-heading">{{ block.settings.col_heading_brands | default: 'Brands' | upcase }}</p>

      {%- if brand_list and brand_list.links.size > 0 -%}
        <ul class="nv-mega-menu-brand-list" role="list">
          {%- for link in brand_list.links -%}
            <li class="nv-mega-menu-brand-item">
              <a
                href="{{ link.url }}"
                class="nv-mega-menu-brand-link{% if link.active %} is-active{% endif %}"
              >
                <span class="nv-mega-menu-brand-name nv-underline-hover">{{ link.title | escape }}</span>
                {%- if link.object and link.object.all_products_count -%}
                  <span class="nv-mega-menu-brand-count">
                    {{ link.object.all_products_count }}
                  </span>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p style="font-size: 0.8125rem; color: var(--nv-header-color-muted); padding: 0 0 1rem;">
          No brands menu selected.
        </p>
      {%- endif -%}
    </div>

    <div class="nv-mega-menu-col nv-mega-menu-col-featured">
      <div class="nv-mega-menu-featured-header">
        <p class="nv-mega-menu-col-heading" style="margin: 0;">
          {{ block.settings.col_heading_feat | default: 'Featured' | upcase }}
        </p>
        <div class="nv-mega-menu-featured-arrows">
          <button type="button" class="nv-mega-menu-arrow-btn nv-feat-prev exit-left" aria-label="Previous">
           {% render 'icons', icon: 'arrow-left' %}
          </button>
          <button type="button" class="nv-mega-menu-arrow-btn nv-feat-next exit-right" aria-label="Next">
            {% render 'icons', icon: 'arrow-right' %}
          </button>
        </div>
      </div>

      {%- assign featured_products = block.settings.featured_products -%}

      {%- if featured_products != blank and featured_products.count > 0 -%}
        <div class="swiper nv-mega-featured-swiper" id="nv-feat-swiper-{{ block.id }}">
          <div class="swiper-wrapper">
            {%- assign fp_limit = block.settings.featured_products_limit | default: 5 -%}
            {%- for product in featured_products limit: fp_limit -%}
              <div class="swiper-slide">
                <a href="{{ product.url }}" class="nv-mega-menu-product-card" style="text-decoration: none;">
                  <div class="nv-mega-menu-product-title">{{ product.title }}</div>
                  <div class="nv-mega-menu-product-price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="nv-mega-menu-price-original">{{ product.compare_at_price | money }}</span>
                    {%- endif -%}
                    <span class="nv-mega-menu-price-sale">{{ product.price | money }}</span>
                  </div>
                  <div class="nv-mega-menu-product-img-wrap">
                    {%- if product.featured_image -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 400 }}"
                        alt="{{ product.featured_image.alt | escape }}"
                        class="nv-mega-menu-product-img"
                        loading="lazy"
                        width="400"
                        height="{{ 400 | divided_by: product.featured_image.aspect_ratio | round }}"
                      >
                    {%- endif -%}
                  </div>
                </a>
              </div>
            {%- endfor -%}
          </div>
        </div>

        {%- if featured_products.count > 1 -%}
          <div class="nv-mega-menu-dots">
            {%- for product in featured_products limit: fp_limit -%}
              <span class="nv-mega-menu-dot{% if forloop.first %} is-active{% endif %}"></span>
            {%- endfor -%}
          </div>
        {%- endif -%}

      {%- else -%}
        <p style="font-size: 0.875rem; color: var(--nv-header-color-muted);">No products selected.</p>
      {%- endif -%}
    </div>

    <div class="nv-mega-menu-col nv-mega-menu-col-hero">
      {%- if hero_image != blank -%}
        <img
          src="{{ hero_image | image_url: width: 900 }}"
          alt="{{ hero_image.alt | escape }}"
          class="nv-mega-menu-hero-img"
          loading="lazy"
          width="900"
          height="600"
        >
      {%- else -%}
        <div style="width: 100%; height: 100%; background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
          <span style="font-size: 0.875rem; color: var(--nv-header-color-muted);">Add hero image</span>
        </div>
      {%- endif -%}

      <div class="nv-mega-menu-marquee-wrap" aria-hidden="true">
        <div class="nv-mega-menu-marquee-row">
          <div class="nv-mega-menu-marquee-track">
            {%- for i in (1..8) -%}
              <span>{{ marquee_text1 }}</span>
              <span class="nv-mega-menu-marquee-sep">—</span>
              <span>{{ marquee_text2 }}</span>
              <span class="nv-mega-menu-marquee-sep">—</span>
            {%- endfor -%}
            {%- for i in (1..8) -%}
              <span>{{ marquee_text1 }}</span>
              <span class="nv-mega-menu-marquee-sep">—</span>
              <span>{{ marquee_text2 }}</span>
              <span class="nv-mega-menu-marquee-sep">—</span>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
  </div>
