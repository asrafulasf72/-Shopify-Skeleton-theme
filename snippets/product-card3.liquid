{% comment %}
  Snippet : product-card3.liquid
  Usage   : {% render 'product-card3', product: product %}
{% endcomment %}

{%- liquid
  assign compare_price = product.compare_at_price
  assign current_price = product.price
  assign on_sale = false
  if compare_price > current_price
    assign on_sale = true
  endif
  assign product_url = product.url | within: collection
  assign primary_img = product.featured_image
-%}

<div class="pc_card">

  {%- comment %} ── Header: Title + Price + Badge ── {% endcomment %}
  <div class="pc_card-header">
    <div>
      <h2 class="title">{{ product.title }}</h2>
      <div class="price">
        {%- if on_sale -%}
          <span class="old-price">{{ compare_price | money }}</span>
          <span class="new-price">{{ current_price | money }}</span>
        {%- else -%}
          <span class="new-price">{{ current_price | money }}</span>
        {%- endif -%}
      </div>
    </div>
    {%- if on_sale -%}
      <span class="badge">On Sale</span>
    {%- else -%}
      <span class="badge">New</span>
    {%- endif -%}
  </div>

  {%- comment %} ── Product Image ── {% endcomment %}
  <div class="image-box">
    <a href="{{ product_url }}">
      {%- if primary_img -%}
        <img
          src="{{ primary_img | image_url: width: 600 }}"
          alt="{{ primary_img.alt | escape | default: product.title }}"
          width="600" height="600"
          loading="lazy"
        >
      {%- else -%}
        <div class="img-placeholder"></div>
      {%- endif -%}
    </a>
  </div>

  {%- comment %} ── Dots ── {% endcomment %}
  <div class="dots">
    <span></span>
    <span class="active"></span>
    <span></span>
  </div>

  {%- comment %} ── Bottom Area: Nav + Actions ── {% endcomment %}
  <div class="bottom-area">
    <div class="bottom-inner">
      <div class="pc_nav">
        <button class="nav-btn" aria-label="Previous">&#8592;</button>
        <button class="nav-btn" aria-label="Next">&#8594;</button>
      </div>
      <div class="actions">
        <button class="action-btn border-right" type="button">Quick view</button>
        <button class="action-btn" type="button">Add to bag</button>
      </div>
    </div>
  </div>

</div>