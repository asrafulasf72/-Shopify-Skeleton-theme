<div class="mega-wrapper">
  {% for block in blocks %}
    {% assign handle = block.settings.link_name | handle %}

    <div class="mega-panel" data-menu="{{ handle }}" {{ block.shopify_attributes }}>
      <div class="mega-inner">

        <!-- LINK COLUMNS -->
        <div class="mega-links">
          {% for i in (1..3) %}
            {% assign list_id = "link_list_" | append: i %}
            {% assign linklist = linklists[block.settings[list_id]] %}
            {% if linklist and linklist.links.size > 0 %}
              <div class="mega-col">
                <p class="mega-col__title">{{ linklist.title }}</p>
                <ul>
                  {% for link in linklist.links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <!-- IMAGE CARDS -->
        <div class="mega-cards">
          {% if block.settings.first_image %}
            <a href="{{ block.settings.first_image_url }}" class="mega-card">
              <img src="{{ block.settings.first_image | image_url: width: 400 }}" alt="" width="" height="">
              <div class="mega-card__overlay">
                <span class="mega-card__highlight">{{ block.settings.highlight_overlay_text }}</span>
                <span class="mega-card__sub">{{ block.settings.overlay_text }}</span>
              </div>
            </a>
          {% endif %}
          {% if block.settings.second_image %}
            <a href="{{ block.settings.second_image_url }}" class="mega-card">
              <img src="{{ block.settings.second_image | image_url: width: 400 }}" alt="" width="" height="">
              <div class="mega-card__overlay">
                <span class="mega-card__highlight">{{ block.settings.highlight_overlay_text_second }}</span>
                <span class="mega-card__sub">{{ block.settings.overlay_text_second }}</span>
              </div>
            </a>
          {% endif %}
        </div>

      </div>
    </div>
  {% endfor %}
</div>

{% style %}
  .mega-wrapper {
  position: absolute;
  top: 100%;
  left: 0;
  width: 100%;
  z-index: 999;
}

.mega-panel {
  display: none;
  background: #fff;
  padding: 2rem 3rem;
  box-shadow: 0 20px 50px rgba(0,0,0,0.12);
  border-top: 1px solid #f0f0f0;
}

.mega-panel.active { display: block; }

.mega-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 2rem;
  max-width: 80rem;
  margin: 0 auto;
}

/* Link columns */
.mega-links {
  display: flex;
  gap: 3rem;
}

.mega-col__title {
  font-weight: 600;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #6b7280;
  margin-bottom: 0.75rem;
}

.mega-col ul { list-style: none; margin: 0; padding: 0; }
.mega-col ul li { margin-bottom: 0.5rem; }
.mega-col ul li a {
  font-size: 0.9rem;
  color: #111827;
  text-decoration: none;
  transition: color 0.15s;
}
.mega-col ul li a:hover { color: #b45309; }

/* Image cards */
.mega-cards {
  display: flex;
  gap: 1rem;
}

.mega-card {
  position: relative;
  width: 200px;
  border-radius: 0.5rem;
  overflow: hidden;
  display: block;
}

.mega-card img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  display: block;
}

.mega-card__overlay {
  position: absolute;
  bottom: 0.75rem;
  left: 0.75rem;
  display: flex;
  flex-direction: column;
}

.mega-card__highlight {
  font-weight: 700;
  color: #b45309;
  font-size: 1rem;
}

.mega-card__sub {
  font-size: 0.85rem;
  color: #111827;
  font-weight: 600;
}
{% endstyle %}
