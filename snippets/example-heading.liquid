{% doc %}
  Renders a reusable heading with optional subheading.

  @param {string} heading - Main heading text.
  @param {string} [subheading] - Optional subheading text.
  @param {number} [parallax_offset] - Optional parallax offset for Swiper

  @example
  {% render 'example-heading', heading: 'Welcome', subheading: 'Our latest products' %}
{% enddoc %}

<div class="example-heading" aria-labelledby="example-heading-title" 
     {% if parallax_offset %}data-swiper-parallax="{{ parallax_offset }}"{% endif %}>
  <h2 id="example-heading-title" class="example-heading__title">
    {{ heading | default: 'Heading' | escape }}
  </h2>
  {% if subheading %}
    <p class="example-heading__subheading">
      {{ subheading | escape }}
    </p>
  {% endif %}
</div>

{% stylesheet %}
  .example-heading {
    opacity: 0;
    animation: fadeInUp 0.8s ease forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .example-heading__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #ffffff 0%, #e0e0e0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .example-heading__subheading {
    font-size: clamp(1rem, 3vw, 1.25rem);
    line-height: 1.6;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .example-heading__title {
      margin-bottom: 0.75rem;
    }
  }
{% endstylesheet %}