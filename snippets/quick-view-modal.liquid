{% doc %}
  Renders the quick view modal container for the featured collection section.

  @param {section} section - The parent section object (used for unique IDs)
{% enddoc %}

<quick-view-modal
  id="quick-view-modal-{{ section.id }}"
  class="qv-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Quick view"
  hidden
>
  <div class="qv-backdrop" data-qv-close></div>

  <div class="qv-modal">
    <button class="qv-close" data-qv-close aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L17 17M17 1L1 17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="qv-loading" aria-live="polite">
      <span class="qv-spinner"></span>
    </div>

    <div class="qv-content" hidden></div>
  </div>
</quick-view-modal>