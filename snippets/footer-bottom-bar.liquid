<div
  class="nv-footer-bottom"
  role="contentinfo"
  aria-label="{{ 'general.accessibility.footer_bottom' | t | default: 'Footer bottom' }}"
>
  <div class="">
    <div class="nv-footer-bottom-row">
      {%- comment -%} Country Selector {%- endcomment -%}
      {%- if show_country -%}
        <div class="nv-footer-localization">
          {%- form 'localization', id: 'nv-localization-form', class: 'nv-localization-form' -%}
            <input
              type="hidden"
              name="country_code"
              value="{{ localization.country.iso_code }}"
              id="nv-country-input"
            >

            <input
              type="hidden"
              name="locale_code"
              value="{{ localization.language.iso_code }}"
              id="nv-language-input"
            >

            <!-- MAIN TRIGGER -->
            <button
              type="button"
              class="nv-localization-trigger"
              aria-expanded="false"
              aria-controls="nv-localization-panel"
            >
              <span>
                {{ localization.language.endonym_name }}
                <span aria-hidden="true" class="nv-footer-local-divider"> | </span>
                ({{ localization.country.currency.iso_code }}
                {{ localization.country.currency.symbol }})
              </span>

              <span class="nv-localization-trigger-icon" aria-hidden="true">
                {% render 'icons', icon: "arrow-down-outline" %}
              </span>
            </button>

            <!-- MAIN PANEL -->
            <div
              class="nv-localization-panel"
              id="nv-localization-panel"
            >
              <!-- LANGUAGE -->
              <div class="nv-locale-group">
                <button
                  type="button"
                  class="nv-locale-toggle"
                  data-target="language"
                >
                  <span>Language</span>

                  <span class="nv-locale-toggle-right">
                    <span>
                      {{ localization.language.endonym_name }}
                    </span>

                    <span class="nv-locale-toggle-icon" aria-hidden="true">
                      {% render 'icons', icon: "arrow-right-outline" %}
                    </span>
                  </span>
                </button>
                <div
                  data-lenis-prevent
                  class="nv-locale-content "
                  data-content="language"
                >
                  {%- for language in localization.available_languages -%}
                    <button
                      type="button"
                      class="nv-locale-option {% if language.iso_code == localization.language.iso_code %}is-active{% endif %}"
                      data-language="{{ language.iso_code }}"
                    >
                      {% if language.iso_code == localization.language.iso_code %}
                        <span class="nv-local-option-check">
                          {% render 'icons', icon: "check-2" %}
                        </span>
                      {% endif %}
                      <span>
                        {{ language.endonym_name }}
                      </span>
                    </button>
                  {%- endfor -%}
                </div>
              </div>

              <!-- CURRENCY -->
              <div class="nv-locale-group">
                <button
                  type="button"
                  class="nv-locale-toggle"
                  data-target="country"
                >
                  <span>Currency</span>

                  <span class="nv-locale-toggle-right">
                    <span>
                      {{ localization.country.currency.iso_code }}
                    </span>

                    <span class="nv-locale-toggle-icon" aria-hidden="true">
                      {% render 'icons', icon: "arrow-right-outline" %}
                    </span>
                  </span>
                </button>

                <div
                  data-lenis-prevent
                  class="nv-locale-content"
                  data-content="country"
                >
                  {%- for country in localization.available_countries -%}
                    <button
                      type="button"
                      class="nv-locale-option {% if country.iso_code == localization.country.iso_code %}is-active{% endif %}"
                      data-country="{{ country.iso_code }}"
                    >
                      {% if country.iso_code == localization.country.iso_code %}
                        <span class="nv-local-option-currency-check">
                          {% render 'icons', icon: "check-2" %}
                        </span>
                      {% endif %}
                      <span>
                        {{ country.name }}
                        ({{ country.currency.iso_code }}
                        {{ country.currency.symbol }})
                      </span>
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            </div>
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- comment -%} Left group {%- endcomment -%}
      <div class="nv-footer-bottom-left">
        {%- if section.settings.copyright_text != blank -%}
          <div class="nv-footer-copyright-text">
            {{ section.settings.copyright_text }}
          </div>
        {%- endif -%}

        {%- if show_payment -%}
          <ul
            class="nv-footer-payment-list"
            role="list"
            aria-label="Accepted payment methods"
          >
            {%- for type in shop.enabled_payment_types -%}
              <li class="nv-footer-payment-item">
                {{ type | payment_type_svg_tag: class: 'nv-payment-icon' }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  function nvInitLocalization(scope) {
    const root = scope || document;
    const footers = root.classList && root.classList.contains('nv-footer-localization')
      ? [root]
      : root.querySelectorAll('.nv-footer-localization');

    footers.forEach((footer) => {
      const trigger = footer.querySelector('.nv-localization-trigger');
      const panel = footer.querySelector('.nv-localization-panel');

      if (!trigger || !panel) return;
      if (trigger.dataset.nvBound === 'true') return;
      trigger.dataset.nvBound = 'true';

      /* MAIN PANEL TOGGLE */
      trigger.addEventListener('click', () => {
        const isOpen = panel.classList.contains('is-open');
        if (isOpen) {
          panel.classList.remove('is-open');
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          panel.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });

      /* INNER ACCORDION */
      const toggles = footer.querySelectorAll('.nv-locale-toggle');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', () => {
          const target = toggle.dataset.target;
          const currentContent = footer.querySelector(`[data-content="${target}"]`);
          const isAlreadyOpen = currentContent.classList.contains('is-open');

          footer.querySelectorAll('.nv-locale-content').forEach((content) => {
            content.classList.remove('is-open');
          });
          footer.querySelectorAll('.nv-locale-toggle').forEach((item) => {
            item.classList.remove('is-active');
          });

          if (!isAlreadyOpen) {
            currentContent.classList.add('is-open');
            toggle.classList.add('is-active');
          }
        });
      });

      /* LANGUAGE */
      footer.querySelectorAll('[data-language]').forEach((option) => {
        option.addEventListener('click', () => {
          const input = footer.querySelector('#nv-language-input');
          input.value = option.dataset.language;
          footer.querySelector('#nv-localization-form').submit();
        });
      });

      /* COUNTRY */
      footer.querySelectorAll('[data-country]').forEach((option) => {
        option.addEventListener('click', () => {
          const input = footer.querySelector('#nv-country-input');
          input.value = option.dataset.country;
          footer.querySelector('#nv-localization-form').submit();
        });
      });
    });
  }


  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => nvInitLocalization());
  } else {
    nvInitLocalization();
  }


  document.addEventListener('shopify:section:load', (event) => {
    nvInitLocalization(event.target);
  });

  /* OUTSIDE CLICK */
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.nv-footer-localization')) {
      document.querySelectorAll('.nv-localization-panel.is-open').forEach((panel) => {
        panel.classList.remove('is-open');
      });
      document.querySelectorAll('.nv-localization-trigger').forEach((trigger) => {
        trigger.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>
